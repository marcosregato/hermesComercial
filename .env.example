# Configurações de Banco de Dados - Hermes Comercial
# COPIE ESTE ARQUIVO PARA .env E PREENCHA COM SEUS DADOS

# PostgreSQL (Principal)
POSTGRES_URL=jdbc:postgresql://localhost:5432/hermescomercialdb
POSTGRES_USER=seu_usuario_postgres
POSTGRES_PASSWORD=sua_senha_postgres
POSTGRES_DRIVER=org.postgresql.Driver

# MySQL (Alternativa)
MYSQL_URL=jdbc:mysql://localhost/hermescomercialdb
MYSQL_USER=seu_usuario_mysql
MYSQL_PASSWORD=sua_senha_mysql
MYSQL_DRIVER=com.mysql.cj.jdbc.Driver

# SQLite (Local)
SQLITE_URL=jdbc:sqlite:hermescomercial.db
SQLITE_DRIVER=org.sqlite.JDBC

# Configurações da Aplicação
APP_NAME=Hermes Comercial PDV
APP_VERSION=1.2.0
APP_ENV=development

# Logging
LOG_LEVEL=INFO
LOG_FILE_PATH=./logs/hermes_comercial.log

# Pool de Conexões
DB_POOL_SIZE=10
DB_POOL_TIMEOUT=30000
