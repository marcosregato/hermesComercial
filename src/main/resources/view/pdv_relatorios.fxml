<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="borderPane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.br.hermescomercial.controller.pdv.PDVRelatoriosController">
   <top>
      <VBox style="-fx-background-color: #2c3e50;">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10; -fx-background-color: #34495e;">
               <children>
                  <Button fx:id="btnVoltar" text="« Voltar" styleClass="button-secondary" onAction="#onVoltar"/>
                  <Label text="RELATÓRIOS PDV" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                  <Region />
                  <Label fx:id="lblDataHora" text="01/01/2024 12:00:00" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
               </children>
            </HBox>
         </children>
      </VBox>
   </top>
   
   <center>
      <VBox spacing="15" style="-fx-padding: 20;">
         <children>
            <!-- Filtros do Relatório -->
            <TitledPane text="Filtros do Relatório" expanded="true" collapsible="false">
               <content>
                  <VBox spacing="10" style="-fx-padding: 10;">
                     <children>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                           <children>
                              <VBox spacing="5">
                                 <children>
                                    <Label text="Tipo de Relatório:*"/>
                                    <ComboBox fx:id="comboTipoRelatorio" prefWidth="250"/>
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        
                        <HBox spacing="10" alignment="CENTER_LEFT">
                           <children>
                              <VBox spacing="5">
                                 <children>
                                    <Label text="Data Inicial:*"/>
                                    <DatePicker fx:id="dpDataInicial" prefWidth="150"/>
                                 </children>
                              </VBox>
                              <VBox spacing="5">
                                 <children>
                                    <Label text="Data Final:*"/>
                                    <DatePicker fx:id="dpDataFinal" prefWidth="150"/>
                                 </children>
                              </VBox>
                              <VBox spacing="5">
                                 <children>
                                    <Label text="Operador:"/>
                                    <ComboBox fx:id="comboOperador" prefWidth="200"/>
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        
                        <HBox spacing="10" alignment="CENTER_LEFT">
                           <children>
                              <VBox spacing="5">
                                 <children>
                                    <Label text="Terminal:"/>
                                    <ComboBox fx:id="comboTerminal" prefWidth="150"/>
                                 </children>
                              </VBox>
                              <VBox spacing="5">
                                 <children>
                                    <Label text="Forma Pagamento:"/>
                                    <ComboBox fx:id="comboFormaPagamento" prefWidth="150"/>
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        
                        <HBox spacing="10" alignment="CENTER_LEFT">
                           <children>
                              <CheckBox fx:id="chkAgruparPorDia" text="Agrupar por Dia"/>
                              <CheckBox fx:id="chkAgruparPorOperador" text="Agrupar por Operador"/>
                              <CheckBox fx:id="chkAgruparPorFormaPagamento" text="Agrupar por Forma Pagamento"/>
                              <CheckBox fx:id="chkMostrarCancelados" text="Incluir Cancelados"/>
                           </children>
                        </HBox>
                        
                        <HBox spacing="10" alignment="CENTER_LEFT">
                           <children>
                              <Button fx:id="btnGerarRelatorio" text="Gerar Relatório" />
                              <Button fx:id="btnLimparFiltros" text="Limpar Filtros" />
                              <Button fx:id="btnExportarPDF" text="Exportar PDF"  disable="true"/>
                              <Button fx:id="btnExportarExcel" text="Exportar Excel"  disable="true"/>
                              <Button fx:id="btnImprimir" text="Imprimir"  disable="true"/>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </content>
            </TitledPane>
            
            <!-- Resultados do Relatório -->
            <TitledPane text="Resultados do Relatório" expanded="true" collapsible="false" >
               <content>
                  <VBox spacing="10" >
                     <children>
                        <!-- Resumo do Relatório -->
                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 10; -fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-radius: 5;">
                           <children>
                              <VBox spacing="5">
                                 <children>
                                    <Label text="Total de Vendas:" style="-fx-font-weight: bold;"/>
                                    <Label fx:id="lblTotalVendas" text="0" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #3498db;"/>
                                 </children>
                              </VBox>
                              <VBox spacing="5">
                                 <children>
                                    <Label text="Valor Total:" style="-fx-font-weight: bold;"/>
                                    <Label fx:id="lblValorTotal" text="R$ 0,00" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                                 </children>
                              </VBox>
                              <VBox spacing="5">
                                 <children>
                                    <Label text="Ticket Médio:" style="-fx-font-weight: bold;"/>
                                    <Label fx:id="lblTicketMedio" text="R$ 0,00" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #f39c12;"/>
                                 </children>
                              </VBox>
                              <VBox spacing="5">
                                 <children>
                                    <Label text="Canceladas:" style="-fx-font-weight: bold;"/>
                                    <Label fx:id="lblVendasCanceladas" text="0" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        
                        <!-- Tabs com diferentes visualizações -->
                        <TabPane >
                           <tabs>
                              <!-- Tab de Vendas Detalhadas -->
                              <Tab text="Vendas Detalhadas" closable="false">
                                 <content>
                                    <TableView fx:id="tblVendasDetalhadas" >
                                       <columns>
                                          <TableColumn fx:id="colVendaData" text="Data" prefWidth="100"/>
                                          <TableColumn fx:id="colVendaNumero" text="Nº Cupom" prefWidth="80"/>
                                          <TableColumn fx:id="colVendaOperador" text="Operador" prefWidth="120"/>
                                          <TableColumn fx:id="colVendaCliente" text="Cliente" prefWidth="150"/>
                                          <TableColumn fx:id="colVendaValor" text="Valor" prefWidth="80"/>
                                          <TableColumn fx:id="colVendaForma" text="Forma Pagamento" prefWidth="100"/>
                                          <TableColumn fx:id="colVendaStatus" text="Status" prefWidth="60"/>
                                          <TableColumn fx:id="colVendaAcoes" text="Ações" prefWidth="80"/>
                                       </columns>
                                    </TableView>
                                 </content>
                              </Tab>
                              
                              <!-- Tab de Produtos Mais Vendidos -->
                              <Tab text="Produtos Mais Vendidos" closable="false">
                                 <content>
                                    <TableView fx:id="tblProdutosMaisVendidos" >
                                       <columns>
                                          <TableColumn fx:id="colProdutoNome" text="Produto" prefWidth="200"/>
                                          <TableColumn fx:id="colProdutoQuantidade" text="Qtd Vendida" prefWidth="80"/>
                                          <TableColumn fx:id="colProdutoValor" text="Valor Total" prefWidth="80"/>
                                          <TableColumn fx:id="colProdutoPercentual" text="Perc Total" prefWidth="60"/>
                                       </columns>
                                    </TableView>
                                 </content>
                              </Tab>
                              
                              <!-- Tab de Formas de Pagamento -->
                              <Tab text="Formas de Pagamento" closable="false">
                                 <content>
                                    <VBox spacing="10" style="-fx-padding: 10;">
                                       <children>
                                          <TableView fx:id="tblFormasPagamento" prefHeight="200" >
                                             <columns>
                                                <TableColumn fx:id="colFormaNome" text="Forma Pagamento" prefWidth="150"/>
                                                <TableColumn fx:id="colFormaQuantidade" text="Qtd" prefWidth="60"/>
                                                <TableColumn fx:id="colFormaValor" text="Valor" prefWidth="80"/>
                                                <TableColumn fx:id="colFormaPercentual" text="Perc Total" prefWidth="60"/>
                                             </columns>
                                          </TableView>
                                          
                                          <!-- Gráfico de Pizza (Placeholder) -->
                                          <VBox spacing="5" alignment="CENTER" style="-fx-padding: 20; -fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-radius: 5;">
                                             <children>
                                                <Label text="GRÁFICO DE FORMAS DE PAGAMENTO" style="-fx-font-weight: bold;"/>
                                                <Label text="[Gráfico de Pizza]" style="-fx-font-size: 24px; -fx-text-fill: #6c757d;"/>
                                             </children>
                                          </VBox>
                                       </children>
                                    </VBox>
                                 </content>
                              </Tab>
                              
                              <!-- Tab de Vendas por Hora -->
                              <Tab text="Vendas por Hora" closable="false">
                                 <content>
                                    <VBox spacing="10" style="-fx-padding: 10;">
                                       <children>
                                          <TableView fx:id="tblVendasPorHora" prefHeight="200" >
                                             <columns>
                                                <TableColumn fx:id="colHoraPeriodo" text="Período" prefWidth="100"/>
                                                <TableColumn fx:id="colHoraQuantidade" text="Qtd Vendas" prefWidth="80"/>
                                                <TableColumn fx:id="colHoraValor" text="Valor" prefWidth="80"/>
                                                <TableColumn fx:id="colHoraPercentual" text="Perc Total" prefWidth="60"/>
                                             </columns>
                                          </TableView>
                                          
                                          <!-- Gráfico de Barras (Placeholder) -->
                                          <VBox spacing="5" alignment="CENTER" style="-fx-padding: 20; -fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-radius: 5;">
                                             <children>
                                                <Label text="GRÁFICO DE VENDAS POR HORA" style="-fx-font-weight: bold;"/>
                                                <Label text="[Gráfico de Barras]" style="-fx-font-size: 24px; -fx-text-fill: #6c757d;"/>
                                             </children>
                                          </VBox>
                                       </children>
                                    </VBox>
                                 </content>
                              </Tab>
                              
                              <!-- Tab de Operadores -->
                              <Tab text="Desempenho por Operador" closable="false">
                                 <content>
                                    <TableView fx:id="tblDesempenhoOperadores" >
                                       <columns>
                                          <TableColumn fx:id="colOperadorNome" text="Operador" prefWidth="150"/>
                                          <TableColumn fx:id="colOperadorVendas" text="Vendas" prefWidth="60"/>
                                          <TableColumn fx:id="colOperadorValor" text="Valor" prefWidth="80"/>
                                          <TableColumn fx:id="colOperadorTicket" text="Ticket Médio" prefWidth="80"/>
                                          <TableColumn fx:id="colOperadorCanceladas" text="Canceladas" prefWidth="60"/>
                                       </columns>
                                    </TableView>
                                 </content>
                              </Tab>
                           </tabs>
                        </TabPane>
                     </children>
                  </VBox>
               </content>
            </TitledPane>
         </children>
      </VBox>
   </center>
   
   <bottom>
      <HBox style="-fx-padding: 10; -fx-background-color: #34495e; -fx-alignment: center_left;" spacing="20">
         <children>
            <Label fx:id="lblStatus" text="Selecione os filtros e gere o relatório" style="-fx-text-fill: #f39c12; -fx-font-weight: bold;"/>
            <Region />
            <Label fx:id="lblOperador" text="Operador: João" style="-fx-text-fill: white;"/>
            <Label fx:id="lblTerminal" text="Terminal: 001" style="-fx-text-fill: white; -fx-padding: 0 0 0 20;"/>
         </children>
      </HBox>
   </bottom>
   
</BorderPane>
