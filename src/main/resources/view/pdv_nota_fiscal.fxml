<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="borderPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.br.hermescomercial.controller.pdv.PDVNotaFiscalController">
   <top>
      <VBox style="-fx-background-color: #2c3e50;">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10; -fx-background-color: #34495e;">
               <children>
                  <Button fx:id="btnVoltar" text="« Voltar" styleClass="button-secondary" onAction="#onVoltar"/>
                  <Label text="GERENCIAMENTO DE NOTA FISCAL" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                  <Region />
                  <Label fx:id="lblDataHora" text="01/01/2024 12:00:00" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
               </children>
            </HBox>
         </children>
      </VBox>
   </top>
   
   <center>
      <VBox spacing="20" style="-fx-padding: 20;">
         <children>
            <!-- Dados da Nota Fiscal -->
            <GridPane hgap="20" vgap="10" style="-fx-background-color: #ecf0f1; -fx-padding: 15; -fx-background-radius: 10;">
               <children>
                  <Label text="Dados da Nota Fiscal" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" GridPane.columnIndex="0" GridPane.rowIndex="0" GridPane.columnSpan="4"/>
                  
                  <Label text="Número:" GridPane.columnIndex="0" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>
                  <Label fx:id="lblNumero" text="000000001" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                  
                  <Label text="Série:" GridPane.columnIndex="2" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>
                  <Label fx:id="lblSerie" text="001" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
                  
                  <Label text="Modelo:" GridPane.columnIndex="0" GridPane.rowIndex="2" style="-fx-font-weight: bold;"/>
                  <Label fx:id="lblModelo" text="65 - NFC-e" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                  
                  <Label text="Status:" GridPane.columnIndex="2" GridPane.rowIndex="2" style="-fx-font-weight: bold;"/>
                  <Label fx:id="lblStatus" text="EM ELABORAÇÃO" style="-fx-text-fill: #f39c12; -fx-font-weight: bold;" GridPane.columnIndex="3" GridPane.rowIndex="2"/>
                  
                  <Label text="Data Emissão:" GridPane.columnIndex="0" GridPane.rowIndex="3" style="-fx-font-weight: bold;"/>
                  <Label fx:id="lblDataEmissao" text="01/01/2024 12:00:00" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                  
                  <Label text="Chave Acesso:" GridPane.columnIndex="2" GridPane.rowIndex="3" style="-fx-font-weight: bold;"/>
                  <Label fx:id="lblChaveAcesso" text="35240112345678900123550010000000012345678901" style="-fx-font-size: 10px;" GridPane.columnIndex="3" GridPane.rowIndex="3"/>
               </children>
               <columnConstraints>
                  <ColumnConstraints minWidth="80" prefWidth="80"/>
                  <ColumnConstraints minWidth="120" prefWidth="150"/>
                  <ColumnConstraints minWidth="80" prefWidth="80"/>
                  <ColumnConstraints minWidth="150" prefWidth="200"/>
               </columnConstraints>
               <rowConstraints>
                  <RowConstraints minHeight="30" prefHeight="30"/>
                  <RowConstraints minHeight="25" prefHeight="25"/>
                  <RowConstraints minHeight="25" prefHeight="25"/>
                  <RowConstraints minHeight="25" prefHeight="25"/>
               </rowConstraints>
            </GridPane>
            
            <!-- Dados do Emitente e Destinatário -->
            <SplitPane dividerPositions="0.5">
               <items>
                  <!-- Emitente -->
                  <VBox spacing="10" style="-fx-background-color: #ffffff; -fx-padding: 15; -fx-border-color: #bdc3c7; -fx-border-radius: 5;">
                     <children>
                        <Label text="EMITENTE" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                        <VBox spacing="5">
                           <children>
                              <Label fx:id="lblEmitenteNome" text="Hermes Comercial Ltda" style="-fx-font-weight: bold;"/>
                              <Label fx:id="lblEmitenteCnpj" text="12.345.678/0001-99"/>
                              <Label fx:id="lblEmitenteEndereco" text="Rua Comercial, 123 - São Paulo/SP"/>
                              <Label fx:id="lblEmitenteTelefone" text="(11) 1234-5678"/>
                           </children>
                        </VBox>
                     </children>
                  </VBox>
                  
                  <!-- Destinatário -->
                  <VBox spacing="10" style="-fx-background-color: #ffffff; -fx-padding: 15; -fx-border-color: #bdc3c7; -fx-border-radius: 5;">
                     <children>
                        <Label text="DESTINATÁRIO" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                        <VBox spacing="5">
                           <children>
                              <Label fx:id="lblDestinatarioNome" text="João Silva" style="-fx-font-weight: bold;"/>
                              <Label fx:id="lblDestinatarioCpfCnpj" text="123.456.789-00"/>
                              <Label fx:id="lblDestinatarioEndereco" text="Rua das Flores, 456 - São Paulo/SP"/>
                              <Label fx:id="lblDestinatarioTelefone" text="(11) 9876-5432"/>
                           </children>
                        </VBox>
                     </children>
                  </VBox>
               </items>
            </SplitPane>
            
            <!-- Itens da Nota Fiscal -->
            <VBox spacing="10" style="-fx-background-color: #ffffff; -fx-padding: 15; -fx-border-color: #bdc3c7; -fx-border-radius: 5;">
               <children>
                  <HBox alignment="CENTER_LEFT" spacing="10">
                     <children>
                        <Label text="ITENS DA NOTA FISCAL" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnAdicionarItem" text="Adicionar Item" styleClass="button-primary"/>
                     </children>
                  </HBox>
                  
                  <TableView fx:id="tblItens" VBox.vgrow="ALWAYS" style="-fx-max-height: 200;">
                     <columns>
                        <TableColumn fx:id="colCodigo" text="Código" prefWidth="80"/>
                        <TableColumn fx:id="colDescricao" text="Descrição" prefWidth="200"/>
                        <TableColumn fx:id="colQuantidade" text="Qtd" prefWidth="60"/>
                        <TableColumn fx:id="colValorUnitario" text="Valor Unit." prefWidth="100"/>
                        <TableColumn fx:id="colValorTotal" text="Valor Total" prefWidth="100"/>
                        <TableColumn fx:id="colAcoes" text="Ações" prefWidth="80"/>
                     </columns>
                  </TableView>
               </children>
            </VBox>
            
            <!-- Valores e Totais -->
            <SplitPane dividerPositions="0.6">
               <items>
                  <!-- Totais -->
                  <VBox spacing="10" style="-fx-background-color: #ffffff; -fx-padding: 15; -fx-border-color: #bdc3c7; -fx-border-radius: 5;">
                     <children>
                        <Label text="TOTAIS" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                        
                        <GridPane hgap="10" vgap="5">
                           <children>
                              <Label text="Total Produtos:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                              <Label fx:id="lblTotalProdutos" text="R$ 0,00" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-font-weight: bold;"/>
                              
                              <Label text="Desconto:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                              <Label fx:id="lblDesconto" text="R$ 0,00" GridPane.columnIndex="1" GridPane.rowIndex="2" style="-fx-text-fill: #e74c3c; -fx-font-weight: bold;"/>
                              
                              <Label text="Frete:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                              <Label fx:id="lblFrete" text="R$ 0,00" GridPane.columnIndex="1" GridPane.rowIndex="3" style="-fx-font-weight: bold;"/>
                              
                              <Separator GridPane.columnIndex="0" GridPane.rowIndex="4" GridPane.columnSpan="2"/>
                              
                              <Label text="Valor Total NF:" GridPane.columnIndex="0" GridPane.rowIndex="5" style="-fx-font-weight: bold;"/>
                              <Label fx:id="lblValorTotalNf" text="R$ 0,00" GridPane.columnIndex="1" GridPane.rowIndex="5" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                           </children>
                           <columnConstraints>
                              <ColumnConstraints minWidth="120" prefWidth="120"/>
                              <ColumnConstraints minWidth="100" prefWidth="120"/>
                           </columnConstraints>
                        </GridPane>
                     </children>
                  </VBox>
                  
                  <!-- Impostos -->
                  <VBox spacing="10" style="-fx-background-color: #ffffff; -fx-padding: 15; -fx-border-color: #bdc3c7; -fx-border-radius: 5;">
                     <children>
                        <Label text="IMPOSTOS" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                        
                        <GridPane hgap="10" vgap="5">
                           <children>
                              <Label text="Base Cálculo ICMS:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                              <Label fx:id="lblBaseIcms" text="R$ 0,00" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                              
                              <Label text="Valor ICMS:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                              <Label fx:id="lblValorIcms" text="R$ 0,00" GridPane.columnIndex="1" GridPane.rowIndex="1" style="-fx-text-fill: #e74c3c; -fx-font-weight: bold;"/>
                              
                              <Label text="Valor IPI:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                              <Label fx:id="lblValorIpi" text="R$ 0,00" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                              
                              <Label text="Valor PIS:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                              <Label fx:id="lblValorPis" text="R$ 0,00" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                              
                              <Label text="Valor COFINS:" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                              <Label fx:id="lblValorCofins" text="R$ 0,00" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                           </children>
                           <columnConstraints>
                              <ColumnConstraints minWidth="120" prefWidth="120"/>
                              <ColumnConstraints minWidth="100" prefWidth="120"/>
                           </columnConstraints>
                        </GridPane>
                     </children>
                  </VBox>
               </items>
            </SplitPane>
            
            <!-- Pagamentos -->
            <VBox spacing="10" style="-fx-background-color: #ffffff; -fx-padding: 15; -fx-border-color: #bdc3c7; -fx-border-radius: 5;">
               <children>
                  <Label text="FORMA DE PAGAMENTO" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
                  
                  <TableView fx:id="tblPagamentos" style="-fx-max-height: 100;">
                     <columns>
                        <TableColumn fx:id="colFormaPagamento" text="Forma Pagamento" prefWidth="150"/>
                        <TableColumn fx:id="colValorPagamento" text="Valor" prefWidth="100"/>
                     </columns>
                  </TableView>
               </children>
            </VBox>
            
            <!-- Ações -->
            <HBox spacing="10" alignment="CENTER_RIGHT">
               <children>
                  <Button fx:id="btnValidar" text="Validar" styleClass="button-info"/>
                  <Button fx:id="btnEmitir" text="Emitir NF" styleClass="button-success"/>
                  <Button fx:id="btnImprimir" text="Imprimir" styleClass="button-secondary" disable="true"/>
                  <Button fx:id="btnCancelar" text="Cancelar NF" styleClass="button-danger" disable="true"/>
                  <Button fx:id="btnConsultar" text="Consultar Status" styleClass="button-warning"/>
               </children>
            </HBox>
         </children>
      </VBox>
   </center>
   
   <bottom>
      <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10; -fx-background-color: #ecf0f1;">
         <children>
            <Label fx:id="lblStatus" text="Nota fiscal em elaboração" style="-fx-text-fill: #f39c12; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label text="Operador:" style="-fx-font-weight: bold;"/>
            <Label fx:id="lblOperador" text="João Silva"/>
         </children>
      </HBox>
   </bottom>
</BorderPane>
