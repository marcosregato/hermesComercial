<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="borderPane" styleClass="border-pane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.br.hermescomercial.controller.pdv.PDVPrincipalController">
   <top>
      <VBox style="-fx-background-color: #2c3e50;">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="header-box" style="-fx-padding: 10; -fx-background-color: #34495e;">
               <children>
                  <Label text="HERMES COMERCIAL - PDV" styleClass="header-title" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
                  <Region HBox.hgrow="ALWAYS"/>
                  <Label fx:id="lblDataHora" text="01/01/2024 12:00:00" styleClass="header-label" style="-fx-text-fill: white;"/>
                  <Label fx:id="lblOperador" text="Operador: João" styleClass="header-label" style="-fx-text-fill: white; -fx-padding: 0 0 0 20;"/>
                  <Label fx:id="lblTerminal" text="Terminal: 001" styleClass="header-label" style="-fx-text-fill: white; -fx-padding: 0 0 0 20;"/>
                  <Label fx:id="lblStatusCaixa" text="Caixa: FECHADO" styleClass="header-label" style="-fx-text-fill: #e74c3c; -fx-font-weight: bold; -fx-padding: 0 0 0 20;"/>
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="hbox-responsive" style="-fx-padding: 5 10; -fx-background-color: #2c3e50;">
               <children>
                  <!-- Grupo Vendas -->
                  <VBox spacing="5">
                     <children>
                        <Label text="VENDAS" style="-fx-text-fill: #ecf0f1; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 0 0 2px 0;"/>
                        <HBox spacing="5">
                           <children>
                              <Button fx:id="btnAbrirVenda" text="Abrir Venda" styleClass="button-success, button-responsive" prefWidth="100.0" onAction="#onAbrirVenda"/>
                              <Button fx:id="btnFecharVenda" text="Fechar Venda" styleClass="button-warning, button-responsive" prefWidth="100.0" onAction="#onFecharVenda"/>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
                  
                  <Separator orientation="VERTICAL" style="-fx-background-color: #34495e; -fx-padding: 0 5 0 5;"/>
                  
                  <!-- Grupo Produtos -->
                  <VBox spacing="5">
                     <children>
                        <Label text="PRODUTOS" style="-fx-text-fill: #ecf0f1; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 0 0 2px 0;"/>
                        <HBox spacing="5">
                           <children>
                              <Button fx:id="btnBuscarProduto" text="Buscar Produto" styleClass="button-info, button-responsive" prefWidth="100.0" onAction="#onBuscarProduto"/>
                              <Button fx:id="btnCadastrarProduto" text="Cadastrar Produto" styleClass="button-primary, button-responsive" prefWidth="100.0" onAction="#onCadastrarProduto"/>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
                  
                  <Separator orientation="VERTICAL" style="-fx-background-color: #34495e; -fx-padding: 0 5 0 5;"/>
                  
                  <!-- Grupo Clientes -->
                  <VBox spacing="5">
                     <children>
                        <Label text="CLIENTES" style="-fx-text-fill: #ecf0f1; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 0 0 2px 0;"/>
                        <Button fx:id="btnClientes" text="Clientes" styleClass="button-info, button-responsive" prefWidth="100.0" onAction="#onClientes"/>
                     </children>
                  </VBox>
                  
                  <Separator orientation="VERTICAL" style="-fx-background-color: #34495e; -fx-padding: 0 5 0 5;"/>
                  
                  <!-- Grupo Relatórios -->
                  <VBox spacing="5">
                     <children>
                        <Label text="RELATÓRIOS" style="-fx-text-fill: #ecf0f1; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 0 0 2px 0;"/>
                        <HBox spacing="5">
                           <children>
                              <Button fx:id="btnRelatorios" text="Relatórios" styleClass="button-info, button-responsive" prefWidth="100.0" onAction="#onRelatorios"/>
                              <Button fx:id="btnNotaFiscal" text="Nota Fiscal" styleClass="button-secondary, button-responsive" prefWidth="100.0" onAction="#onNotaFiscal"/>
                              <Button fx:id="btnCupomFiscal" text="Cupom Fiscal" styleClass="button-secondary, button-responsive" prefWidth="100.0" onAction="#onCupomFiscal"/>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
                  
                  <Separator orientation="VERTICAL" style="-fx-background-color: #34495e; -fx-padding: 0 5 0 5;"/>
                  
                  <!-- Grupo Sistema -->
                  <VBox spacing="5">
                     <children>
                        <Label text="SISTEMA" style="-fx-text-fill: #ecf0f1; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 0 0 2px 0;"/>
                        <Button fx:id="btnConfigSistema" text="Config. Sistema" styleClass="button-dark, button-responsive" prefWidth="100.0" onAction="#onConfigSistema"/>
                     </children>
                  </VBox>
                  
                  <Region HBox.hgrow="ALWAYS"/>
                  
                  <!-- Grupo Caixa -->
                  <VBox spacing="5">
                     <children>
                        <Label text="CAIXA" style="-fx-text-fill: #ecf0f1; -fx-font-size: 10px; -fx-font-weight: bold; -fx-padding: 0 0 2px 0;"/>
                        <HBox spacing="5">
                           <children>
                              <Button fx:id="btnAbrirCaixa" text="Abrir Caixa" styleClass="button-success, button-responsive" prefWidth="100.0" onAction="#onAbrirCaixa"/>
                              <Button fx:id="btnFecharCaixa" text="Fechar Caixa" styleClass="button-danger, button-responsive" prefWidth="100.0" onAction="#onFecharCaixa"/>
                              <Button fx:id="btnSair" text="Sair" styleClass="button-danger, button-responsive" prefWidth="80.0" onAction="#onSair"/>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </HBox>
         </children>
      </VBox>
   </top>
   
   <!-- Painel de Informações do Caixa (visível quando caixa estiver aberto) -->
   <VBox fx:id="painelCaixaAberto" style="-fx-background-color: #27ae60; -fx-padding: 10; -fx-spacing: 5;" managed="false" visible="false">
      <children>
         <HBox alignment="CENTER_LEFT" spacing="15">
            <children>
               <Label text="CAIXA ABERTO" style="-fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold;"/>
               <Region />
               <Label fx:id="lblDataAbertura" text="Aberto em: 19/04/2026 15:38" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
               <Label fx:id="lblOperadorCaixa" text="Operador: João" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 0 0 0 20;"/>
               <Label fx:id="lblValorCaixa" text="Valor em Caixa: R$ 0,00" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 0 0 0 20;"/>
            </children>
         </HBox>
      </children>
   </VBox>
   
   <center>
      <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-padding: 5;">
         <content>
            <VBox spacing="20" styleClass="content-vbox" style="-fx-padding: 20;">
               <children>
                  <!-- Área de Cliente -->
                  <TitledPane text="Cliente" expanded="true" collapsible="false">
                     <content>
                        <VBox spacing="10">
                           <children>
                              <!-- Campos de Busca Lado a Lado -->
                              <HBox spacing="15" alignment="CENTER_LEFT">
                                 <children>
                                    <!-- Busca por Nome -->
                                    <VBox spacing="5">
                                       <children>
                                          <Label text="Nome:" style="-fx-font-weight: bold;"/>
                                          <HBox spacing="5" alignment="CENTER_LEFT">
                                             <children>
                                                <TextField fx:id="txtBuscarClienteNome" promptText="Digite o nome do cliente..." prefWidth="250" styleClass="text-field-search"/>
                                                <Button fx:id="btnBuscarClienteNome" text="Buscar" styleClass="button-primary" onAction="#onBuscarClienteNome"/>
                                             </children>
                                          </HBox>
                                       </children>
                                    </VBox>
                                    
                                    <!-- Busca por CPF/CNPJ -->
                                    <VBox spacing="5">
                                       <children>
                                          <Label text="CPF/CNPJ:" style="-fx-font-weight: bold;"/>
                                          <HBox spacing="5" alignment="CENTER_LEFT">
                                             <children>
                                                <TextField fx:id="txtBuscarClienteCpfCnpj" promptText="Digite o CPF ou CNPJ..." prefWidth="200" styleClass="text-field-search"/>
                                                <Button fx:id="btnBuscarClienteCpfCnpj" text="Buscar" styleClass="button-primary" onAction="#onBuscarClienteCpfCnpj"/>
                                             </children>
                                          </HBox>
                                       </children>
                                    </VBox>
                                 </children>
                              </HBox>
                              
                              <!-- Botões de Ação -->
                              <HBox spacing="10" alignment="CENTER_LEFT">
                                 <children>
                                    <Button fx:id="btnNovoCliente" text="Novo Cliente" styleClass="button-success" onAction="#onNovoCliente"/>
                                    <Button fx:id="btnLimparCliente" text="Limpar Campos" styleClass="button-secondary" onAction="#onLimparCliente"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="lblClienteSelecionado" text="Nenhum cliente selecionado" style="-fx-text-fill: #666; -fx-font-style: italic;"/>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </content>
                  </TitledPane>
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </center>
   
   <bottom>
      <HBox style="-fx-padding: 10; -fx-background-color: #34495e; -fx-alignment: center_left;" spacing="20">
         <children>
            <Label fx:id="lblStatusCaixa" text="Caixa: ABERTO" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
            <Label fx:id="lblValorCaixa" text="Valor em Caixa: R$ 1.000,00" style="-fx-text-fill: white;"/>
            <Region />
            <Label fx:id="lblStatus" text="Pronto para operar" style="-fx-text-fill: #28a745; -fx-font-weight: bold;"/>
         </children>
      </HBox>
   </bottom>
   
</BorderPane>
