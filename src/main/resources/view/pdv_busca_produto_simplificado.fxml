<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="borderPane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.br.hermescomercial.controller.pdv.PDVBuscaProdutoController">
   <top>
      <VBox style="-fx-background-color: #2c3e50;">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10; -fx-background-color: #34495e;">
               <children>
                  <Button fx:id="btnVoltar" text="« Voltar" styleClass="button-secondary" onAction="#onVoltar"/>
                  <Label text="BUSCA DE PRODUTOS" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                  <Region />
                  <Label fx:id="lblDataHora" text="01/01/2024 12:00:00" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
               </children>
            </HBox>
         </children>
      </VBox>
   </top>
   
   <center>
      <VBox spacing="15" style="-fx-padding: 20;">
         <children>
            <!-- Área de Busca -->
            <TitledPane text="Filtros de Busca" expanded="true" collapsible="false">
               <content>
                  <VBox spacing="10" style="-fx-padding: 10;">
                     <children>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                           <children>
                              <VBox spacing="5">
                                 <children>
                                    <Label text="Código de Barras:"/>
                                    <TextField fx:id="txtCodigoBarras" promptText="Digite o código de barras..." />
                                 </children>
                              </VBox>
                              <VBox spacing="5">
                                 <children>
                                    <Label text="Código Interno:"/>
                                    <TextField fx:id="txtCodigoInterno" promptText="Digite o código..." />
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        
                        <HBox spacing="10" alignment="CENTER_LEFT">
                           <children>
                              <VBox spacing="5">
                                 <children>
                                    <Label text="Descrição do Produto:"/>
                                    <TextField fx:id="txtDescricao" promptText="Digite a descrição..." />
                                 </children>
                              </VBox>
                              <VBox spacing="5">
                                 <children>
                                    <Label text="Categoria:"/>
                                    <ComboBox fx:id="comboCategoria" prefWidth="200"/>
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        
                        <HBox spacing="10" alignment="CENTER_LEFT">
                           <children>
                              <VBox spacing="5">
                                 <children>
                                    <Label text="Preço Mínimo:"/>
                                    <TextField fx:id="txtPrecoMinimo" promptText="0,00"/>
                                 </children>
                              </VBox>
                              <VBox spacing="5">
                                 <children>
                                    <Label text="Preço Máximo:"/>
                                    <TextField fx:id="txtPrecoMaximo" promptText="0,00"/>
                                 </children>
                              </VBox>
                              <VBox spacing="5">
                                 <children>
                                    <Label text="Estoque Mínimo:"/>
                                    <TextField fx:id="txtEstoqueMinimo" promptText="0"/>
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                        
                        <HBox spacing="10" alignment="CENTER_LEFT">
                           <children>
                              <CheckBox fx:id="chkApenasComEstoque" text="Apenas produtos com estoque"/>
                              <CheckBox fx:id="chkApenasAtivos" text="Apenas produtos ativos" selected="true"/>
                              <Region />
                              <Button fx:id="btnBuscar" text="Buscar" styleClass="button-primary"/>
                              <Button fx:id="btnLimpar" text="Limpar Filtros" styleClass="button-secondary"/>
                              <Button fx:id="btnLeitorCodigo" text="Usar Leitor" styleClass="button-info"/>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </content>
            </TitledPane>
            
            <!-- Resultados da Busca -->
            <TitledPane text="Resultados da Busca" expanded="true" collapsible="false">
               <content>
                  <VBox spacing="10">
                     <children>
                        <!-- Barra de Status -->
                        <HBox alignment="CENTER_LEFT" style="-fx-padding: 5; -fx-background-color: #f8f9fa; -fx-border-color: #dee2e6;">
                           <children>
                              <Label fx:id="lblResultados" text="0 produtos encontrados" style="-fx-font-weight: bold;"/>
                              <Region />
                              <Label fx:id="lblTempoBusca" text="Tempo: 0ms" style="-fx-text-fill: #6c757d; -fx-font-size: 12px;"/>
                           </children>
                        </HBox>
                        
                        <!-- Tabela de Produtos -->
                        <TableView fx:id="tblProdutos" styleClass="table-view">
                           <columns>
                              <TableColumn fx:id="colCodigo" text="Código" prefWidth="80"/>
                              <TableColumn fx:id="colCodigoBarras" text="Cód. Barras" prefWidth="120"/>
                              <TableColumn fx:id="colDescricao" text="Descrição" prefWidth="250"/>
                              <TableColumn fx:id="colCategoria" text="Categoria" prefWidth="100"/>
                              <TableColumn fx:id="colUnidade" text="Un." prefWidth="50"/>
                              <TableColumn fx:id="colPrecoVenda" text="Preço Venda" prefWidth="80"/>
                              <TableColumn fx:id="colEstoque" text="Estoque" prefWidth="70"/>
                              <TableColumn fx:id="colStatus" text="Status" prefWidth="60"/>
                              <TableColumn fx:id="colAcoes" text="Ações" prefWidth="150"/>
                           </columns>
                        </TableView>
                        
                        <!-- Botões de Ação -->
                        <HBox spacing="10" alignment="CENTER_RIGHT">
                           <children>
                              <Button fx:id="btnAdicionarAoCarrinho" text="Adicionar ao Carrinho" styleClass="button-success"/>
                              <Button fx:id="btnVerDetalhes" text="Ver Detalhes" styleClass="button-info"/>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </content>
            </TitledPane>
         </VBox>
      </content>
   </center>
   
   <bottom>
      <HBox style="-fx-padding: 10; -fx-background-color: #34495e; -fx-alignment: center_left;" spacing="20">
         <children>
            <Label fx:id="lblStatus" text="Pronto para busca" style="-fx-text-fill: #28a745; -fx-font-weight: bold;"/>
            <Region />
            <Label fx:id="lblOperador" text="Operador: João" style="-fx-text-fill: white;"/>
            <Label fx:id="lblTerminal" text="Terminal: 001" style="-fx-text-fill: white; -fx-padding: 0 0 0 20;"/>
         </children>
      </HBox>
   </bottom>
   
   <stylesheets>
      <URL value="@../css/pdv.css"/>
   </stylesheets>
</BorderPane>
