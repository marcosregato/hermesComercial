<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="borderPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.br.hermescomercial.controller.pdv.PDVClientesController">
   <top>
      <VBox style="-fx-background-color: #2c3e50;">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10; -fx-background-color: #34495e;">
               <children>
                  <Button fx:id="btnVoltar" text="« Voltar" styleClass="button-secondary" onAction="#onVoltar"/>
                  <Label text="GERENCIAMENTO DE CLIENTES" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                  <Region />
                  <Label fx:id="lblDataHora" text="01/01/2024 12:00:00" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
               </children>
            </HBox>
         </children>
      </VBox>
   </top>
   
   <center>
      <SplitPane dividerPositions="0.4" style="-fx-padding: 10;">
         <items>
            <!-- Painel Esquerdo - Busca e Lista -->
            <VBox spacing="10">
               <children>
                  <!-- Área de Busca -->
                  <TitledPane text="Busca de Clientes" expanded="true" collapsible="false">
                     <content>
                        <VBox spacing="10" style="-fx-padding: 10;">
                           <children>
                              <HBox spacing="5" alignment="CENTER_LEFT">
                                 <children>
                                    <TextField fx:id="txtBuscarCliente" promptText="Digite CPF/CNPJ ou Nome..." styleClass="text-field-search"/>
                                    <Button fx:id="btnBuscar" text="Buscar" styleClass="button-primary"/>
                                    <Button fx:id="btnLimparBusca" text="Limpar" styleClass="button-secondary"/>
                                 </children>
                              </HBox>
                              
                              <HBox spacing="10" alignment="CENTER_LEFT">
                                 <children>
                                    <CheckBox fx:id="chkApenasAtivos" text="Apenas ativos" selected="true"/>
                                    <CheckBox fx:id="chkPessoaFisica" text="Pessoa Física"/>
                                    <CheckBox fx:id="chkPessoaJuridica" text="Pessoa Jurídica"/>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </content>
                  </TitledPane>
                  
                  <!-- Lista de Clientes -->
                  <TitledPane text="Clientes Encontrados" expanded="true" collapsible="false" VBox.vgrow="ALWAYS">
                     <content>
                        <VBox spacing="5" VBox.vgrow="ALWAYS">
                           <children>
                              <TableView fx:id="tblClientes" VBox.vgrow="ALWAYS" styleClass="table-view">
                                 <columns>
                                    <TableColumn fx:id="colNome" text="Nome" prefWidth="200"/>
                                    <TableColumn fx:id="colDocumento" text="CPF/CNPJ" prefWidth="120"/>
                                    <TableColumn fx:id="colTelefone" text="Telefone" prefWidth="100"/>
                                    <TableColumn fx:id="colCidade" text="Cidade" prefWidth="100"/>
                                    <TableColumn fx:id="colStatus" text="Status" prefWidth="60"/>
                                 </columns>
                              </TableView>
                              
                              <HBox spacing="5" alignment="CENTER">
                                 <children>
                                    <Button fx:id="btnNovoCliente" text="Novo Cliente" styleClass="button-success"/>
                                    <Button fx:id="btnEditarCliente" text="Editar" styleClass="button-warning" disable="true"/>
                                    <Button fx:id="btnSelecionarCliente" text="Selecionar" styleClass="button-primary" disable="true"/>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </content>
                  </TitledPane>
               </children>
            </VBox>
            
            <!-- Painel Direito - Formulário -->
            <VBox spacing="10">
               <children>
                  <TitledPane text="Dados do Cliente" expanded="true" collapsible="false" VBox.vgrow="ALWAYS">
                     <content>
                        <ScrollPane fitToWidth="true" hbarPolicy="NEVER">
                           <VBox spacing="10" style="-fx-padding: 10;">
                              <children>
                                 <!-- Tipo de Pessoa -->
                                 <HBox spacing="10" alignment="CENTER_LEFT">
                                    <children>
                                       <Label text="Tipo de Pessoa:" style="-fx-font-weight: bold;"/>
                                       <RadioButton fx:id="rbPessoaFisica" text="Pessoa Física" selected="true"/>
                                       <RadioButton fx:id="rbPessoaJuridica" text="Pessoa Jurídica"/>
                                    </children>
                                 </HBox>
                                 
                                 <Separator/>
                                 
                                 <!-- Dados Principais -->
                                 <VBox fx:id="panePessoaFisica" spacing="5">
                                    <children>
                                       <HBox spacing="10" alignment="CENTER_LEFT">
                                          <children>
                                             <VBox spacing="5">
                                                <children>
                                                   <Label text="Nome Completo:*"/>
                                                   <TextField fx:id="txtNome" promptText="Nome completo do cliente"/>
                                                </children>
                                             </VBox>
                                          </children>
                                       </HBox>
                                       
                                       <HBox spacing="10" alignment="CENTER_LEFT">
                                          <children>
                                             <VBox spacing="5">
                                                <children>
                                                   <Label text="CPF:*"/>
                                                   <TextField fx:id="txtCPF" promptText="000.000.000-00"/>
                                                </children>
                                             </VBox>
                                             <VBox spacing="5">
                                                <children>
                                                   <Label text="RG:*"/>
                                                   <TextField fx:id="txtRG" promptText="MG-XX.XXX.XXX"/>
                                                </children>
                                             </VBox>
                                          </children>
                                       </HBox>
                                       
                                       <HBox spacing="10" alignment="CENTER_LEFT">
                                          <children>
                                             <VBox spacing="5">
                                                <children>
                                                   <Label text="Data Nascimento:*"/>
                                                   <DatePicker fx:id="dpDataNascimento" prefWidth="200"/>
                                                </children>
                                             </VBox>
                                          </children>
                                       </HBox>
                                    </children>
                                 </VBox>
                                 
                                 <VBox fx:id="panePessoaJuridica" spacing="5" visible="false">
                                    <children>
                                       <HBox spacing="10" alignment="CENTER_LEFT">
                                          <children>
                                             <VBox spacing="5">
                                                <children>
                                                   <Label text="Razão Social:*"/>
                                                   <TextField fx:id="txtRazaoSocial" promptText="Razão social da empresa"/>
                                                </children>
                                             </VBox>
                                          </children>
                                       </HBox>
                                       
                                       <HBox spacing="10" alignment="CENTER_LEFT">
                                          <children>
                                             <VBox spacing="5">
                                                <children>
                                                   <Label text="Nome Fantasia:*"/>
                                                   <TextField fx:id="txtNomeFantasia" promptText="Nome fantasia"/>
                                                </children>
                                             </VBox>
                                          </children>
                                       </HBox>
                                       
                                       <HBox spacing="10" alignment="CENTER_LEFT">
                                          <children>
                                             <VBox spacing="5">
                                                <children>
                                                   <Label text="CNPJ:*"/>
                                                   <TextField fx:id="txtCNPJ" promptText="00.000.000/0000-00"/>
                                                </children>
                                             </VBox>
                                             <VBox spacing="5">
                                                <children>
                                                   <Label text="Inscrição Estadual:"/>
                                                   <TextField fx:id="txtInscricaoEstadual" promptText="Isento"/>
                                                </children>
                                             </VBox>
                                          </children>
                                       </HBox>
                                    </children>
                                 </VBox>
                                 
                                 <Separator/>
                                 
                                 <!-- Contato -->
                                 <VBox spacing="5">
                                    <children>
                                       <Label text="Dados de Contato" style="-fx-font-weight: bold;"/>
                                       
                                       <HBox spacing="10" alignment="CENTER_LEFT">
                                          <children>
                                             <VBox spacing="5">
                                                <children>
                                                   <Label text="Telefone:*"/>
                                                   <TextField fx:id="txtTelefone" promptText="(00) 0000-0000"/>
                                                </children>
                                             </VBox>
                                             <VBox spacing="5">
                                                <children>
                                                   <Label text="Celular:"/>
                                                   <TextField fx:id="txtCelular" promptText="(00) 00000-0000"/>
                                                </children>
                                             </VBox>
                                          </children>
                                       </HBox>
                                       
                                       <HBox spacing="10" alignment="CENTER_LEFT">
                                          <children>
                                             <VBox spacing="5">
                                                <children>
                                                   <Label text="E-mail:*"/>
                                                   <TextField fx:id="txtEmail" promptText="email@exemplo.com"/>
                                                </children>
                                             </VBox>
                                          </children>
                                       </HBox>
                                    </children>
                                 </VBox>
                                 
                                 <Separator/>
                                 
                                 <!-- Endereço -->
                                 <VBox spacing="5">
                                    <children>
                                       <Label text="Endereço" style="-fx-font-weight: bold;"/>
                                       
                                       <HBox spacing="10" alignment="CENTER_LEFT">
                                          <children>
                                             <VBox spacing="5">
                                                <children>
                                                   <Label text="CEP:*"/>
                                                   <TextField fx:id="txtCEP" promptText="00000-000"/>
                                                </children>
                                             </VBox>
                                             <Button fx:id="btnBuscarCEP" text="Buscar CEP" styleClass="button-info"/>
                                          </children>
                                       </HBox>
                                       
                                       <HBox spacing="10" alignment="CENTER_LEFT">
                                          <children>
                                             <VBox spacing="5">
                                                <children>
                                                   <Label text="Endereço:*"/>
                                                   <TextField fx:id="txtEndereco" promptText="Rua, Avenida, etc."/>
                                                </children>
                                             </VBox>
                                             <VBox spacing="5">
                                                <children>
                                                   <Label text="Número:*"/>
                                                   <TextField fx:id="txtNumero" promptText="0"/>
                                                </children>
                                             </VBox>
                                          </children>
                                       </HBox>
                                       
                                       <HBox spacing="10" alignment="CENTER_LEFT">
                                          <children>
                                             <VBox spacing="5">
                                                <children>
                                                   <Label text="Complemento:"/>
                                                   <TextField fx:id="txtComplemento" promptText="Apto, Casa, etc."/>
                                                </children>
                                             </VBox>
                                             <VBox spacing="5">
                                                <children>
                                                   <Label text="Bairro:*"/>
                                                   <TextField fx:id="txtBairro" promptText="Centro"/>
                                                </children>
                                             </VBox>
                                          </children>
                                       </HBox>
                                       
                                       <HBox spacing="10" alignment="CENTER_LEFT">
                                          <children>
                                             <VBox spacing="5">
                                                <children>
                                                   <Label text="Cidade:*"/>
                                                   <TextField fx:id="txtCidade" promptText="São Paulo"/>
                                                </children>
                                             </VBox>
                                             <VBox spacing="5">
                                                <children>
                                                   <Label text="Estado:*"/>
                                                   <ComboBox fx:id="comboEstado" prefWidth="100"/>
                                                </children>
                                             </VBox>
                                          </children>
                                       </HBox>
                                    </children>
                                 </VBox>
                                 
                                 <Separator/>
                                 
                                 <!-- Informações Adicionais -->
                                 <VBox spacing="5">
                                    <children>
                                       <Label text="Informações Adicionais" style="-fx-font-weight: bold;"/>
                                       
                                       <VBox spacing="5">
                                          <children>
                                             <Label text="Observações:"/>
                                             <TextArea fx:id="txtObservacoes" promptText="Observações sobre o cliente..." prefHeight="80"/>
                                          </children>
                                       </VBox>
                                       
                                       <HBox spacing="10" alignment="CENTER_LEFT">
                                          <children>
                                             <CheckBox fx:id="chkAtivo" text="Cliente Ativo" selected="true"/>
                                          </children>
                                       </HBox>
                                    </children>
                                 </VBox>
                                 
                                 <!-- Botões de Ação -->
                                 <HBox spacing="10" alignment="CENTER" style="-fx-padding: 10 0;">
                                    <children>
                                       <Button fx:id="btnSalvar" text="Salvar" styleClass="button-success"/>
                                       <Button fx:id="btnLimpar" text="Limpar" styleClass="button-secondary"/>
                                       <Button fx:id="btnExcluir" text="Excluir" styleClass="button-danger" disable="true"/>
                                    </children>
                                 </HBox>
                              </children>
                           </VBox>
                        </ScrollPane>
                     </content>
                  </TitledPane>
               </children>
            </VBox>
         </items>
      </SplitPane>
   </center>
   
   <bottom>
      <HBox style="-fx-padding: 10; -fx-background-color: #34495e; -fx-alignment: center_left;" spacing="20">
         <children>
            <Label fx:id="lblStatus" text="Pronto para operar" style="-fx-text-fill: #28a745; -fx-font-weight: bold;"/>
            <Region />
            <Label fx:id="lblOperador" text="Operador: João" style="-fx-text-fill: white;"/>
            <Label fx:id="lblTerminal" text="Terminal: 001" style="-fx-text-fill: white; -fx-padding: 0 0 0 20;"/>
         </children>
      </HBox>
   </bottom>
   
</BorderPane>
