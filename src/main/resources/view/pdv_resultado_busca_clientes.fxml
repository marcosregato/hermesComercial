<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="borderPane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.br.hermescomercial.controller.pdv.PDVResultadoBuscaClientesController">
   <top>
      <VBox style="-fx-background-color: #2c3e50;">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10; -fx-background-color: #34495e;">
               <children>
                  <Label text="Resultado da Busca de Clientes" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                  <Region />
                  <Button fx:id="btnFechar" text="Fechar" styleClass="button-danger" onAction="#onFechar"/>
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 5 10; -fx-background-color: #2c3e50;">
               <children>
                  <Label fx:id="lblTermoBusca" text="Termo da busca: " style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                  <Label fx:id="lblQuantidadeResultados" text="Resultados encontrados: 0" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
               </children>
            </HBox>
         </children>
      </VBox>
   </top>
   
   <center>
      <VBox spacing="10" style="-fx-padding: 20;">
         <children>
            <!-- Tabela de Resultados -->
            <TableView fx:id="tblResultados" styleClass="table-view" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
                  <TableColumn fx:id="colNome" text="Nome" prefWidth="200"/>
                  <TableColumn fx:id="colDocumento" text="CPF/CNPJ" prefWidth="120"/>
                  <TableColumn fx:id="colTelefone" text="Telefone" prefWidth="100"/>
                  <TableColumn fx:id="colEmail" text="Email" prefWidth="150"/>
                  <TableColumn fx:id="colAcoes" text="Ações" prefWidth="100"/>
               </columns>
            </TableView>
            
            <!-- Área de Detalhes -->
            <TitledPane text="Detalhes do Cliente Selecionado" expanded="true" collapsible="false">
               <content>
                  <GridPane hgap="10" vgap="5">
                     <children>
                        <Label text="ID:" style="-fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <Label fx:id="lblDetalheId" text="-" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                        
                        <Label text="Nome:" style="-fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <Label fx:id="lblDetalheNome" text="-" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                        
                        <Label text="CPF/CNPJ:" style="-fx-font-weight: bold;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <Label fx:id="lblDetalheDocumento" text="-" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                        
                        <Label text="Telefone:" style="-fx-font-weight: bold;" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <Label fx:id="lblDetalheTelefone" text="-" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                        
                        <Label text="Email:" style="-fx-font-weight: bold;" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                        <Label fx:id="lblDetalheEmail" text="-" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                        
                        <Label text="Endereço:" style="-fx-font-weight: bold;" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                        <Label fx:id="lblDetalheEndereco" text="-" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                     </children>
                     <columnConstraints>
                        <ColumnConstraints minWidth="80" prefWidth="80"/>
                        <ColumnConstraints minWidth="200" prefWidth="300"/>
                     </columnConstraints>
                     <rowConstraints>
                        <RowConstraints minHeight="25"/>
                        <RowConstraints minHeight="25"/>
                        <RowConstraints minHeight="25"/>
                        <RowConstraints minHeight="25"/>
                        <RowConstraints minHeight="25"/>
                        <RowConstraints minHeight="25"/>
                     </rowConstraints>
                  </GridPane>
               </content>
            </TitledPane>
            
            <!-- Botões de Ação -->
            <HBox spacing="10" alignment="CENTER_RIGHT">
               <children>
                  <Button fx:id="btnSelecionar" text="Selecionar Cliente" styleClass="button-primary" onAction="#onSelecionar"/>
                  <Button fx:id="btnNovaBusca" text="Nova Busca" styleClass="button-secondary" onAction="#onNovaBusca"/>
               </children>
            </HBox>
         </children>
      </VBox>
   </center>
</BorderPane>
