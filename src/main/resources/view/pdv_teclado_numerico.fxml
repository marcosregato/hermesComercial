<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      spacing="5" styleClass="vbox-responsive" style="-fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-radius: 5; -fx-padding: 10;">
   <children>
      <!-- Display -->
      <TextField fx:id="txtDisplay" editable="false" styleClass="text-field-responsive" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-alignment: center-right;"/>
      
      <!-- Teclado Numérico -->
      <GridPane hgap="5" vgap="5" styleClass="teclado-grid">
         <children>
            <!-- Linha 1: 7, 8, 9 -->
            <Button fx:id="btn7" text="7" styleClass="button-teclado, teclado-button" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
            <Button fx:id="btn8" text="8" styleClass="button-teclado, teclado-button" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
            <Button fx:id="btn9" text="9" styleClass="button-teclado, teclado-button" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
            
            <!-- Linha 2: 4, 5, 6 -->
            <Button fx:id="btn4" text="4" styleClass="button-teclado, teclado-button" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
            <Button fx:id="btn5" text="5" styleClass="button-teclado, teclado-button" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
            <Button fx:id="btn6" text="6" styleClass="button-teclado, teclado-button" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
            
            <!-- Linha 3: 1, 2, 3 -->
            <Button fx:id="btn1" text="1" styleClass="button-teclado, teclado-button" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
            <Button fx:id="btn2" text="2" styleClass="button-teclado, teclado-button" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
            <Button fx:id="btn3" text="3" styleClass="button-teclado, teclado-button" GridPane.columnIndex="2" GridPane.rowIndex="2"/>
            
            <!-- Linha 4: 0, ., C -->
            <Button fx:id="btn0" text="0" styleClass="button-teclado, teclado-button" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
            <Button fx:id="btnVirgula" text="," styleClass="button-teclado, teclado-button" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
            <Button fx:id="btnLimpar" text="C" styleClass="button-danger, teclado-button" GridPane.columnIndex="2" GridPane.rowIndex="3"/>
            
            <!-- Linha 5: Enter -->
            <Button fx:id="btnEnter" text="ENTER" styleClass="button-success, teclado-button" GridPane.columnIndex="0" GridPane.rowIndex="4" GridPane.columnSpan="3"/>
         </children>
      </GridPane>
   </children>
</VBox>
