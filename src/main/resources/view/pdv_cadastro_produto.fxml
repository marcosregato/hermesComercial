<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="borderPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.br.hermescomercial.controller.pdv.PDVCadastroProdutoController">
   <top>
      <VBox style="-fx-background-color: #2c3e50;">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10; -fx-background-color: #34495e;">
               <children>
                  <Label text="CADASTRO DE PRODUTO" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                  <Region />
                  <Label fx:id="lblDataHora" text="01/01/2024 12:00:00" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                  <Label fx:id="lblOperador" text="Operador: João" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 0 0 0 20;"/>
                  <Label fx:id="lblTerminal" text="Terminal: 001" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 0 0 0 20;"/>
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 5 10; -fx-background-color: #2c3e50;">
               <children>
                  <Button fx:id="btnNovo" text="Novo" styleClass="button-success" onAction="#onNovo"/>
                  <Button fx:id="btnSalvar" text="Salvar" styleClass="button-primary" onAction="#onSalvar"/>
                  <Button fx:id="btnExcluir" text="Excluir" styleClass="button-danger" onAction="#onExcluir"/>
                  <Button fx:id="btnLimpar" text="Limpar" styleClass="button-secondary" onAction="#onLimpar"/>
                  <Region />
                  <Button fx:id="btnVoltar" text="Voltar" styleClass="button-secondary" onAction="#onVoltar"/>
               </children>
            </HBox>
         </children>
      </VBox>
   </top>
   
   <center>
      <ScrollPane fitToWidth="true" fitToHeight="true" style="-fx-background-color: #ecf0f1;">
         <content>
            <VBox spacing="20" style="-fx-padding: 20;">
               <children>
                  <!-- Dados Básicos -->
                  <TitledPane text="Dados Básicos" expanded="true" collapsible="false">
                     <content>
                        <VBox spacing="15" style="-fx-padding: 15;">
                           <children>
                              <!-- Código -->
                              <HBox spacing="10" alignment="CENTER_LEFT">
                                 <children>
                                    <Label text="Código Interno:" style="-fx-font-weight: bold; -fx-min-width: 120;"/>
                                    <TextField fx:id="txtCodigoInterno" promptText="Digite o código interno..." HBox.hgrow="ALWAYS" styleClass="text-field"/>
                                 </children>
                              </HBox>
                              
                              <!-- Código de Barras -->
                              <HBox spacing="10" alignment="CENTER_LEFT">
                                 <children>
                                    <Label text="Código de Barras:" style="-fx-font-weight: bold; -fx-min-width: 120;"/>
                                    <TextField fx:id="txtCodigoBarras" promptText="Digite o código de barras..." HBox.hgrow="ALWAYS" styleClass="text-field"/>
                                 </children>
                              </HBox>
                              
                              <!-- Nome -->
                              <HBox spacing="10" alignment="CENTER_LEFT">
                                 <children>
                                    <Label text="Nome:*" style="-fx-font-weight: bold; -fx-min-width: 120;"/>
                                    <TextField fx:id="txtNome" promptText="Digite o nome do produto..." HBox.hgrow="ALWAYS" styleClass="text-field"/>
                                 </children>
                              </HBox>
                              
                              <!-- Descrição -->
                              <HBox spacing="10" alignment="CENTER_LEFT">
                                 <children>
                                    <Label text="Descrição:" style="-fx-font-weight: bold; -fx-min-width: 120;"/>
                                    <TextArea fx:id="txtDescricao" promptText="Digite a descrição do produto..." HBox.hgrow="ALWAYS" styleClass="text-field" prefRowCount="3"/>
                                 </children>
                              </HBox>
                              
                              <!-- Categoria -->
                              <HBox spacing="10" alignment="CENTER_LEFT">
                                 <children>
                                    <Label text="Categoria:*" style="-fx-font-weight: bold; -fx-min-width: 120;"/>
                                    <ComboBox fx:id="comboCategoria" promptText="Selecione a categoria..." HBox.hgrow="ALWAYS" styleClass="combo-box"/>
                                 </children>
                              </HBox>
                              
                              <!-- Unidade -->
                              <HBox spacing="10" alignment="CENTER_LEFT">
                                 <children>
                                    <Label text="Unidade:*" style="-fx-font-weight: bold; -fx-min-width: 120;"/>
                                    <ComboBox fx:id="comboUnidade" promptText="Selecione a unidade..." HBox.hgrow="ALWAYS" styleClass="combo-box"/>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </content>
                  </TitledPane>
                  
                  <!-- Precificação -->
                  <TitledPane text="Precificação" expanded="true" collapsible="false">
                     <content>
                        <VBox spacing="15" style="-fx-padding: 15;">
                           <children>
                              <!-- Preço de Custo -->
                              <HBox spacing="10" alignment="CENTER_LEFT">
                                 <children>
                                    <Label text="Preço de Custo:*" style="-fx-font-weight: bold; -fx-min-width: 120;"/>
                                    <TextField fx:id="txtPrecoCusto" promptText="0,00" HBox.hgrow="ALWAYS" styleClass="text-field"/>
                                 </children>
                              </HBox>
                              
                              <!-- Preço de Venda -->
                              <HBox spacing="10" alignment="CENTER_LEFT">
                                 <children>
                                    <Label text="Preço de Venda:*" style="-fx-font-weight: bold; -fx-min-width: 120;"/>
                                    <TextField fx:id="txtPrecoVenda" promptText="0,00" HBox.hgrow="ALWAYS" styleClass="text-field"/>
                                 </children>
                              </HBox>
                              
                              <!-- Margem de Lucro -->
                              <HBox spacing="10" alignment="CENTER_LEFT">
                                 <children>
                                    <Label text="Margem de Lucro:" style="-fx-font-weight: bold; -fx-min-width: 120;"/>
                                    <Label fx:id="lblMargemLucro" text="0,00%" style="-fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </content>
                  </TitledPane>
                  
                  <!-- Estoque -->
                  <TitledPane text="Estoque" expanded="true" collapsible="false">
                     <content>
                        <VBox spacing="15" style="-fx-padding: 15;">
                           <children>
                              <!-- Estoque Atual -->
                              <HBox spacing="10" alignment="CENTER_LEFT">
                                 <children>
                                    <Label text="Estoque Atual:" style="-fx-font-weight: bold; -fx-min-width: 120;"/>
                                    <TextField fx:id="txtEstoqueAtual" promptText="0" HBox.hgrow="ALWAYS" styleClass="text-field"/>
                                 </children>
                              </HBox>
                              
                              <!-- Estoque Mínimo -->
                              <HBox spacing="10" alignment="CENTER_LEFT">
                                 <children>
                                    <Label text="Estoque Mínimo:" style="-fx-font-weight: bold; -fx-min-width: 120;"/>
                                    <TextField fx:id="txtEstoqueMinimo" promptText="0" HBox.hgrow="ALWAYS" styleClass="text-field"/>
                                 </children>
                              </HBox>
                              
                              <!-- Estoque Máximo -->
                              <HBox spacing="10" alignment="CENTER_LEFT">
                                 <children>
                                    <Label text="Estoque Máximo:" style="-fx-font-weight: bold; -fx-min-width: 120;"/>
                                    <TextField fx:id="txtEstoqueMaximo" promptText="0" HBox.hgrow="ALWAYS" styleClass="text-field"/>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </content>
                  </TitledPane>
                  
                  <!-- Status -->
                  <TitledPane text="Status" expanded="true" collapsible="false">
                     <content>
                        <VBox spacing="15" style="-fx-padding: 15;">
                           <children>
                              <!-- Ativo -->
                              <HBox spacing="10" alignment="CENTER_LEFT">
                                 <children>
                                    <Label text="Status:" style="-fx-font-weight: bold; -fx-min-width: 120;"/>
                                    <CheckBox fx:id="chkAtivo" text="Produto Ativo" selected="true"/>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </content>
                  </TitledPane>
               </children>
            </VBox>
         </content>
      </ScrollPane>
   </center>
   
   <bottom>
      <HBox spacing="10" alignment="CENTER_LEFT" style="-fx-padding: 10; -fx-background-color: #34495e;">
         <children>
            <Label fx:id="lblStatus" text="Pronto para operar" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
            <Region />
            <Label fx:id="lblMensagem" text="" style="-fx-text-fill: #f39c12; -fx-font-size: 14px; -fx-font-weight: bold;"/>
         </children>
      </HBox>
   </bottom>
</BorderPane>
