<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="borderPane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.br.hermescomercial.controller.pdv.PDVPrincipalController">
   <top>
      <VBox style="-fx-background-color: #2c3e50;">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10; -fx-background-color: #34495e;">
               <children>
                  <Label text="HERMES COMERCIAL - PDV" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                  <Region />
                  <Label fx:id="lblDataHora" text="01/01/2024 12:00:00" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                  <Label fx:id="lblOperador" text="Operador: João" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 0 0 0 20;"/>
                  <Label fx:id="lblTerminal" text="Terminal: 001" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 0 0 0 20;"/>
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 5 10; -fx-background-color: #2c3e50;">
               <children>
                  <Button fx:id="btnAbrirVenda" text="Abrir Venda" styleClass="button-primary" onAction="#onAbrirVenda"/>
                  <Button fx:id="btnBuscarProduto" text="Buscar Produto" styleClass="button-secondary" onAction="#onBuscarProduto"/>
                  <Button fx:id="btnClientes" text="Clientes" styleClass="button-secondary" onAction="#onClientes"/>
                  <Button fx:id="btnRelatorios" text="Relatórios" styleClass="button-secondary" onAction="#onRelatorios"/>
                  <Region />
                  <Button fx:id="btnAbrirCaixa" text="Abrir Caixa" styleClass="button-success" onAction="#onAbrirCaixa"/>
                  <Button fx:id="btnFecharCaixa" text="Fechar Caixa" styleClass="button-danger" onAction="#onFecharCaixa"/>
                  <Button fx:id="btnSair" text="Sair" styleClass="button-danger" onAction="#onSair"/>
               </children>
            </HBox>
         </children>
      </VBox>
   </top>
   
   <center>
      <VBox spacing="20" style="-fx-padding: 20;">
         <children>
            <!-- Área de Produtos -->
            <TitledPane text="Produtos" expanded="true" collapsible="false">
               <content>
                  <VBox spacing="10">
                     <children>
                        <HBox spacing="10" alignment="CENTER_LEFT">
                           <children>
                              <TextField fx:id="txtBuscarProduto" promptText="Digite código ou descrição..." styleClass="text-field-search"/>
                              <Button fx:id="btnBuscar" text="Buscar" styleClass="button-primary" onAction="#onBuscarProduto"/>
                              <Button fx:id="btnCodigoBarras" text="Cód. Barras" styleClass="button-info" onAction="#onCodigoBarras"/>
                           </children>
                        </HBox>
                        
                        <TableView fx:id="tblProdutos" styleClass="table-view">
                           <columns>
                              <TableColumn fx:id="colCodigo" text="Código" prefWidth="80"/>
                              <TableColumn fx:id="colDescricao" text="Descrição" prefWidth="200"/>
                              <TableColumn fx:id="colPreco" text="Preço" prefWidth="80"/>
                              <TableColumn fx:id="colEstoque" text="Estoque" prefWidth="80"/>
                              <TableColumn fx:id="colAcoes" text="Ações" prefWidth="100"/>
                           </columns>
                        </TableView>
                     </children>
                  </VBox>
               </content>
            </TitledPane>
            
            <!-- Área de Cliente -->
            <TitledPane text="Cliente" expanded="true" collapsible="false">
               <content>
                  <HBox spacing="10" alignment="CENTER_LEFT">
                     <children>
                        <TextField fx:id="txtBuscarCliente" promptText="CPF/CNPJ ou Nome..."/>
                        <Button fx:id="btnBuscarCliente" text="Buscar" styleClass="button-primary" onAction="#onBuscarCliente"/>
                        <Button fx:id="btnNovoCliente" text="Novo" styleClass="button-success" onAction="#onNovoCliente"/>
                        <Button fx:id="btnLimparCliente" text="Limpar" styleClass="button-secondary" onAction="#onLimparCliente"/>
                     </children>
                  </HBox>
               </content>
            </TitledPane>
            
            <!-- Carrinho de Compras -->
            <TitledPane text="Carrinho de Compras" expanded="true" collapsible="false">
               <content>
                  <VBox spacing="10">
                     <children>
                        <TableView fx:id="tblCarrinho" styleClass="table-view">
                           <columns>
                              <TableColumn fx:id="colItemCodigo" text="Código" prefWidth="60"/>
                              <TableColumn fx:id="colItemDescricao" text="Descrição" prefWidth="150"/>
                              <TableColumn fx:id="colItemQtd" text="Qtd" prefWidth="50"/>
                              <TableColumn fx:id="colItemValor" text="Valor" prefWidth="80"/>
                              <TableColumn fx:id="colItemTotal" text="Total" prefWidth="80"/>
                              <TableColumn fx:id="colItemAcoes" text="Ações" prefWidth="80"/>
                           </columns>
                        </TableView>
                        
                        <!-- Resumo do Carrinho -->
                        <VBox spacing="5" style="-fx-background-color: #f8f9fa; -fx-padding: 10; -fx-border-color: #dee2e6; -fx-border-radius: 5;">
                           <children>
                              <HBox alignment="CENTER_LEFT">
                                 <children>
                                    <Label text="Subtotal:" style="-fx-font-weight: bold;"/>
                                    <Region />
                                    <Label fx:id="lblSubtotal" text="R$ 0,00" style="-fx-font-weight: bold;"/>
                                 </children>
                              </HBox>
                              <HBox alignment="CENTER_LEFT">
                                 <children>
                                    <Label text="Desconto:" style="-fx-font-weight: bold;"/>
                                    <Region />
                                    <Label fx:id="lblDesconto" text="R$ 0,00" style="-fx-font-weight: bold;"/>
                                 </children>
                              </HBox>
                              <Separator/>
                              <HBox alignment="CENTER_LEFT">
                                 <children>
                                    <Label text="Total:" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #28a745;"/>
                                    <Region />
                                    <Label fx:id="lblTotal" text="R$ 0,00" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #28a745;"/>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                        
                        <!-- Botões de Ação -->
                        <HBox spacing="10" alignment="CENTER">
                           <children>
                              <Button fx:id="btnDesconto" text="Desconto" styleClass="button-warning" onAction="#onDesconto"/>
                              <Button fx:id="btnCancelarItem" text="Cancelar Item" styleClass="button-danger" onAction="#onCancelarItem"/>
                              <Button fx:id="btnLimparCarrinho" text="Limpar Carrinho" styleClass="button-secondary" onAction="#onLimparCarrinho"/>
                              <Button fx:id="btnFinalizar" text="Finalizar Venda" styleClass="button-success" onAction="#onFinalizar"/>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </content>
            </TitledPane>
         </children>
      </VBox>
   </center>
   
   <bottom>
      <HBox style="-fx-padding: 10; -fx-background-color: #34495e; -fx-alignment: center_left;" spacing="20">
         <children>
            <Label fx:id="lblStatusCaixa" text="Caixa: ABERTO" style="-fx-text-fill: white; -fx-font-weight: bold;"/>
            <Label fx:id="lblValorCaixa" text="Valor em Caixa: R$ 1.000,00" style="-fx-text-fill: white;"/>
            <Region />
            <Label fx:id="lblStatus" text="Pronto para operar" style="-fx-text-fill: #28a745; -fx-font-weight: bold;"/>
         </children>
      </HBox>
   </bottom>
   
</BorderPane>
