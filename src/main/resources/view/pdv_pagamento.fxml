<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="borderPane" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.br.hermescomercial.controller.pdv.PDVPagamentoController">
   <top>
      <VBox style="-fx-background-color: #2c3e50;">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10; -fx-background-color: #34495e;">
               <children>
                  <Button fx:id="btnVoltar" text="« Voltar" styleClass="button-secondary" onAction="#onVoltar"/>
                  <Label text="FINALIZAR VENDA - PAGAMENTO" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                  <Region />
                  <Label fx:id="lblDataHora" text="01/01/2024 12:00:00" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
               </children>
            </HBox>
         </children>
      </VBox>
   </top>
   
   <center>
      <HBox spacing="20" style="-fx-padding: 20;">
         <children>
            <!-- Painel Esquerdo - Resumo da Venda -->
            <VBox spacing="15">
               <children>
                  <TitledPane text="Resumo da Venda" expanded="true" collapsible="false">
                     <content>
                        <VBox spacing="10" style="-fx-padding: 10;">
                           <children>
                              <!-- Informações do Cliente -->
                              <HBox alignment="CENTER_LEFT">
                                 <children>
                                    <Label text="Cliente:" style="-fx-font-weight: bold;"/>
                                    <Region />
                                    <Label fx:id="lblCliente" text="Não informado" style="-fx-text-fill: #495057;"/>
                                 </children>
                              </HBox>
                              
                              <Separator/>
                              
                              <!-- Itens da Venda -->
                              <Label text="ITENS DA VENDA" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                              
                              <TableView fx:id="tblItensVenda" prefHeight="200" styleClass="table-view">
                                 <columns>
                                    <TableColumn fx:id="colItemDescricao" text="Descrição" prefWidth="200"/>
                                    <TableColumn fx:id="colItemQtd" text="Qtd" prefWidth="50"/>
                                    <TableColumn fx:id="colItemValor" text="Valor Unit." prefWidth="80"/>
                                    <TableColumn fx:id="colItemTotal" text="Total" prefWidth="80"/>
                                 </columns>
                              </TableView>
                              
                              <!-- Totais -->
                              <VBox spacing="5" style="-fx-background-color: #f8f9fa; -fx-padding: 10; -fx-border-color: #dee2e6; -fx-border-radius: 5;">
                                 <children>
                                    <HBox alignment="CENTER_LEFT">
                                       <children>
                                          <Label text="Subtotal:" style="-fx-font-weight: bold;"/>
                                          <Region />
                                          <Label fx:id="lblSubtotal" text="R$ 0,00" style="-fx-font-weight: bold;"/>
                                       </children>
                                    </HBox>
                                    <HBox alignment="CENTER_LEFT">
                                       <children>
                                          <Label text="Desconto:" style="-fx-font-weight: bold;"/>
                                          <Region />
                                          <Label fx:id="lblDesconto" text="R$ 0,00" style="-fx-font-weight: bold;"/>
                                       </children>
                                    </HBox>
                                    <Separator/>
                                    <HBox alignment="CENTER_LEFT">
                                       <children>
                                          <Label text="TOTAL A PAGAR:" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
                                          <Region />
                                          <Label fx:id="lblTotal" text="R$ 0,00" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
                                       </children>
                                    </HBox>
                                 </children>
                              </VBox>
                           </children>
                        </VBox>
                     </content>
                  </TitledPane>
               </children>
            </VBox>
            
            <!-- Painel Direito - Formas de Pagamento -->
            <VBox spacing="15">
               <children>
                  <TitledPane text="Formas de Pagamento" expanded="true" collapsible="false">
                     <content>
                        <VBox spacing="10" style="-fx-padding: 10;">
                           <children>
                              <!-- Seleção de Forma de Pagamento -->
                              <VBox spacing="5">
                                 <children>
                                    <Label text="Selecione a forma de pagamento:" style="-fx-font-weight: bold;"/>
                                    <ComboBox fx:id="comboFormaPagamento" prefWidth="250"/>
                                    <Label fx:id="lblFormaPagamentoInfo" text="" style="-fx-text-fill: #6c757d; -fx-font-size: 12px;"/>
                                 </children>
                              </VBox>
                              
                              <!-- Pagamento em Dinheiro -->
                              <VBox fx:id="paneDinheiro" spacing="5" visible="false">
                                 <children>
                                    <Label text="VALOR RECEBIDO" style="-fx-font-weight: bold;"/>
                                    <TextField fx:id="txtValorRecebido" promptText="0,00" styleClass="text-field-search"/>
                                    
                                    <HBox spacing="5">
                                       <children>
                                          <Button fx:id="btn5" text="R$ 5" styleClass="button-numeric"/>
                                          <Button fx:id="btn10" text="R$ 10" styleClass="button-numeric"/>
                                          <Button fx:id="btn20" text="R$ 20" styleClass="button-numeric"/>
                                          <Button fx:id="btn50" text="R$ 50" styleClass="button-numeric"/>
                                       </children>
                                    </HBox>
                                    
                                    <HBox spacing="5">
                                       <children>
                                          <Button fx:id="btn100" text="R$ 100" styleClass="button-numeric"/>
                                          <Button fx:id="btn200" text="R$ 200" styleClass="button-numeric"/>
                                          <Button fx:id="btnExato" text="Exato" styleClass="button-success"/>
                                          <Button fx:id="btnLimparValor" text="Limpar" styleClass="button-secondary"/>
                                       </children>
                                    </HBox>
                                    
                                    <Separator/>
                                    
                                    <HBox alignment="CENTER_LEFT">
                                       <children>
                                          <Label text="TROCO:" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                                          <Region />
                                          <Label fx:id="lblTroco" text="R$ 0,00" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                                       </children>
                                    </HBox>
                                 </children>
                              </VBox>
                              
                              <!-- Pagamento Cartão -->
                              <VBox fx:id="paneCartao" spacing="5" visible="false">
                                 <children>
                                    <Label text="DADOS DO CARTÃO" style="-fx-font-weight: bold;"/>
                                    
                                    <HBox spacing="10">
                                       <children>
                                          <VBox spacing="5">
                                             <children>
                                                <Label text="Bandeira:"/>
                                                <ComboBox fx:id="comboBandeira" prefWidth="120"/>
                                             </children>
                                          </VBox>
                                          <VBox spacing="5">
                                             <children>
                                                <Label text="Parcelas:"/>
                                                <ComboBox fx:id="comboParcelas" prefWidth="120"/>
                                             </children>
                                          </VBox>
                                       </children>
                                    </HBox>
                                    
                                    <VBox spacing="5">
                                       <children>
                                          <Label text="Número do Cartão:"/>
                                          <TextField fx:id="txtNumeroCartao" promptText="**** **** **** ****"/>
                                       </children>
                                    </VBox>
                                    
                                    <VBox spacing="5">
                                       <children>
                                          <Label text="Nome no Cartão:"/>
                                          <TextField fx:id="txtNomeCartao" promptText="NOME IMPRESSO NO CARTÃO"/>
                                       </children>
                                    </VBox>
                                    
                                    <HBox spacing="10">
                                       <children>
                                          <VBox spacing="5">
                                             <children>
                                                <Label text="Validade:"/>
                                                <TextField fx:id="txtValidade" promptText="MM/AA" prefWidth="100"/>
                                             </children>
                                          </VBox>
                                          <VBox spacing="5">
                                             <children>
                                                <Label text="CVV:"/>
                                                <TextField fx:id="txtCVV" promptText="***" prefWidth="80"/>
                                             </children>
                                          </VBox>
                                       </children>
                                    </HBox>
                                 </children>
                              </VBox>
                              
                              <!-- Pagamento PIX -->
                              <VBox fx:id="panePIX" spacing="5" visible="false">
                                 <children>
                                    <Label text="PAGAMENTO PIX" style="-fx-font-weight: bold;"/>
                                    <Label text="Escaneie o QR Code ou utilize a chave PIX:" style="-fx-text-fill: #6c757d;"/>
                                    
                                    <VBox spacing="5" alignment="CENTER" style="-fx-padding: 20; -fx-background-color: #f8f9fa; -fx-border-color: #dee2e6; -fx-border-radius: 5;">
                                       <children>
                                          <Label text="[QR CODE]" style="-fx-font-size: 24px; -fx-text-fill: #6c757d;"/>
                                          <Label fx:id="lblChavePIX" text="chave@pix.com.br" style="-fx-font-size: 12px; -fx-text-fill: #495057;"/>
                                       </children>
                                    </VBox>
                                    
                                    <Button fx:id="btnConfirmarPIX" text="Confirmar Pagamento PIX" styleClass="button-success" maxWidth="Infinity"/>
                                 </children>
                              </VBox>
                              
                              <!-- Pagamento Transferência -->
                              <VBox fx:id="paneTransferencia" spacing="5" visible="false">
                                 <children>
                                    <Label text="DADOS PARA TRANSFERÊNCIA" style="-fx-font-weight: bold;"/>
                                    
                                    <VBox spacing="5" style="-fx-background-color: #f8f9fa; -fx-padding: 10; -fx-border-color: #dee2e6; -fx-border-radius: 5;">
                                       <children>
                                          <HBox alignment="CENTER_LEFT">
                                             <children>
                                                <Label text="Banco:" style="-fx-font-weight: bold;"/>
                                                <Region />
                                                <Label fx:id="lblBanco" text="Banco do Brasil - 001"/>
                                             </children>
                                          </HBox>
                                          <HBox alignment="CENTER_LEFT">
                                             <children>
                                                <Label text="Agência:" style="-fx-font-weight: bold;"/>
                                                <Region />
                                                <Label fx:id="lblAgencia" text="1234-5"/>
                                             </children>
                                          </HBox>
                                          <HBox alignment="CENTER_LEFT">
                                             <children>
                                                <Label text="Conta:" style="-fx-font-weight: bold;"/>
                                                <Region />
                                                <Label fx:id="lblConta" text="12345-6"/>
                                             </children>
                                          </HBox>
                                          <HBox alignment="CENTER_LEFT">
                                             <children>
                                                <Label text="CNPJ:" style="-fx-font-weight: bold;"/>
                                                <Region />
                                                <Label fx:id="lblCNPJ" text="12.345.678/0001-95"/>
                                             </children>
                                          </HBox>
                                       </children>
                                    </VBox>
                                    
                                    <Button fx:id="btnConfirmarTransferencia" text="Confirmar Transferência" styleClass="button-success" maxWidth="Infinity"/>
                                 </children>
                              </VBox>
                              
                              <!-- Múltiplos Pagamentos -->
                              <VBox fx:id="paneMultiplos" spacing="5" visible="false">
                                 <children>
                                    <Label text="MÚLTIPLOS PAGAMENTOS" style="-fx-font-weight: bold;"/>
                                    
                                    <TableView fx:id="tblPagamentos" prefHeight="150" styleClass="table-view">
                                       <columns>
                                          <TableColumn fx:id="colPagamentoForma" text="Forma" prefWidth="100"/>
                                          <TableColumn fx:id="colPagamentoValor" text="Valor" prefWidth="80"/>
                                          <TableColumn fx:id="colPagamentoStatus" text="Status" prefWidth="80"/>
                                          <TableColumn fx:id="colPagamentoAcoes" text="Ações" prefWidth="80"/>
                                       </columns>
                                    </TableView>
                                    
                                    <HBox spacing="5">
                                       <children>
                                          <ComboBox fx:id="comboFormaAdicional" prefWidth="150"/>
                                          <TextField fx:id="txtValorAdicional" promptText="0,00"/>
                                          <Button fx:id="btnAdicionarPagamento" text="Adicionar" styleClass="button-primary"/>
                                       </children>
                                    </HBox>
                                    
                                    <Separator/>
                                    
                                    <HBox alignment="CENTER_LEFT">
                                       <children>
                                          <Label text="Total Pago:" style="-fx-font-weight: bold;"/>
                                          <Region />
                                          <Label fx:id="lblTotalPago" text="R$ 0,00" style="-fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                                       </children>
                                    </HBox>
                                    
                                    <HBox alignment="CENTER_LEFT">
                                       <children>
                                          <Label text="Restante:" style="-fx-font-weight: bold;"/>
                                          <Region />
                                          <Label fx:id="lblRestante" text="R$ 0,00" style="-fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
                                       </children>
                                    </HBox>
                                 </children>
                              </VBox>
                              
                              <!-- Botões de Ação -->
                              <HBox spacing="10" alignment="CENTER" style="-fx-padding: 10 0;">
                                 <children>
                                    <Button fx:id="btnCancelar" text="Cancelar Venda" styleClass="button-danger"/>
                                    <Button fx:id="btnProcessar" text="Processar Pagamento" styleClass="button-success"/>
                                    <Button fx:id="btnFinalizar" text="Finalizar Venda" styleClass="button-primary" disable="true"/>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </content>
                  </TitledPane>
               </children>
            </VBox>
         </children>
      </HBox>
   </center>
   
   <bottom>
      <HBox style="-fx-padding: 10; -fx-background-color: #34495e; -fx-alignment: center_left;" spacing="20">
         <children>
            <Label fx:id="lblStatus" text="Aguardando forma de pagamento..." style="-fx-text-fill: #f39c12; -fx-font-weight: bold;"/>
            <Region "ALWAYS"/>
            <Label fx:id="lblOperador" text="Operador: João" style="-fx-text-fill: white;"/>
            <Label fx:id="lblTerminal" text="Terminal: 001" style="-fx-text-fill: white; -fx-padding: 0 0 0 20;"/>
         </children>
      </HBox>
   </bottom>
   
   <stylesheets>
      <URL value="@../css/pdv.css"/>
   </stylesheets>
</BorderPane>
