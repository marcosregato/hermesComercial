<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="borderPane" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.br.hermescomercial.controller.pdv.PDVCupomFiscalController">
   <top>
      <VBox style="-fx-background-color: #2c3e50;">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 10; -fx-background-color: #34495e;">
               <children>
                  <Label text="CUPOM FISCAL" style="-fx-text-fill: white; -fx-font-size: 18px; -fx-font-weight: bold;"/>
                  <Region />
                  <Label fx:id="lblDataHora" text="01/01/2024 12:00:00" style="-fx-text-fill: white; -fx-font-size: 14px;"/>
                  <Label fx:id="lblOperador" text="Operador: João" style="-fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 0 0 0 20;"/>
               </children>
            </HBox>
            <HBox alignment="CENTER_LEFT" spacing="10" style="-fx-padding: 5 10; -fx-background-color: #2c3e50;">
               <children>
                  <Button fx:id="btnNovoCupom" text="Novo Cupom" styleClass="button-primary" onAction="#onNovoCupom"/>
                  <Button fx:id="btnBuscarCupom" text="Buscar" styleClass="button-secondary" onAction="#onBuscarCupom"/>
                  <Button fx:id="btnImprimir" text="Imprimir" styleClass="button-info" onAction="#onImprimir"/>
                  <Button fx:id="btnCancelar" text="Cancelar" styleClass="button-warning" onAction="#onCancelar"/>
                  <Button fx:id="btnEstornar" text="Estornar" styleClass="button-danger" onAction="#onEstornar"/>
                  <Region />
                  <Button fx:id="btnVoltar" text="Voltar" styleClass="button-secondary" onAction="#onVoltar"/>
               </children>
            </HBox>
         </children>
      </VBox>
   </top>
   
   <center>
      <SplitPane dividerPositions="0.6" style="-fx-padding: 10;">
         <items>
            <!-- Área de Visualização do Cupom -->
            <VBox spacing="10">
               <children>
                  <TitledPane text="Visualização do Cupom Fiscal" expanded="true" collapsible="false">
                     <content>
                        <ScrollPane fx:id="scrollPaneCupom" fitToWidth="true" prefHeight="400">
                           <content>
                              <TextArea fx:id="txtAreaCupom" 
                                       styleClass="text-area-cupom" 
                                       editable="false" 
                                       wrapText="true"
                                       prefHeight="400"
                                       style="-fx-font-family: 'Courier New', monospace; -fx-font-size: 12px; -fx-background-color: white; -fx-border-color: #ccc; -fx-border-radius: 5; -fx-padding: 10;"/>
                           </content>
                        </ScrollPane>
                     </content>
                  </TitledPane>
                  
                  <!-- Área de Informações do Cupom -->
                  <TitledPane text="Informações do Cupom" expanded="true" collapsible="false">
                     <content>
                        <GridPane hgap="10" vgap="10" style="-fx-padding: 10;">
                           <children>
                              <Label text="Número:" style="-fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                              <Label fx:id="lblNumeroCupom" text="000001" style="-fx-font-weight: bold;" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                              
                              <Label text="Data Emissão:" style="-fx-font-weight: bold;" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                              <Label fx:id="lblDataEmissao" text="01/01/2024 12:00:00" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                              
                              <Label text="Cliente:" style="-fx-font-weight: bold;" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                              <Label fx:id="lblCliente" text="Não informado" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                              
                              <Label text="Valor Total:" style="-fx-font-weight: bold;" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                              <Label fx:id="lblValorTotal" text="R$ 0,00" style="-fx-font-weight: bold; -fx-text-fill: #28a745; -fx-font-size: 14px;" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                              
                              <Label text="Forma Pagamento:" style="-fx-font-weight: bold;" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                              <Label fx:id="lblFormaPagamento" text="DINHEIRO" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                              
                              <Label text="Status:" style="-fx-font-weight: bold;" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                              <Label fx:id="lblStatus" text="ATIVO" style="-fx-font-weight: bold; -fx-text-fill: #28a745;" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                           </children>
                           <columnConstraints>
                              <ColumnConstraints prefWidth="120" halignment="RIGHT"/>
                              <ColumnConstraints prefWidth="200" halignment="LEFT"/>
                           </columnConstraints>
                           <rowConstraints>
                              <RowConstraints/>
                              <RowConstraints/>
                              <RowConstraints/>
                              <RowConstraints/>
                              <RowConstraints/>
                              <RowConstraints/>
                           </rowConstraints>
                        </GridPane>
                     </content>
                  </TitledPane>
               </children>
            </VBox>
            
            <!-- Área de Busca e Lista de Cupons -->
            <VBox spacing="10">
               <children>
                  <TitledPane text="Busca de Cupons" expanded="true" collapsible="false">
                     <content>
                        <VBox spacing="10" style="-fx-padding: 10;">
                           <children>
                              <HBox spacing="10" alignment="CENTER_LEFT">
                                 <children>
                                    <Label text="Período:" style="-fx-font-weight: bold;"/>
                                    <DatePicker fx:id="dtDataInicio" promptText="Data Início"/>
                                    <Label text="até"/>
                                    <DatePicker fx:id="dtDataFim" promptText="Data Fim"/>
                                 </children>
                              </HBox>
                              
                              <HBox spacing="10" alignment="CENTER_LEFT">
                                 <children>
                                    <Label text="Número:" style="-fx-font-weight: bold; -fx-min-width: 50;"/>
                                    <TextField fx:id="txtNumeroCupom" promptText="Número do cupom..." HBox.hgrow="ALWAYS" styleClass="text-field-search"/>
                                 </children>
                              </HBox>
                              
                              <HBox spacing="10" alignment="CENTER_LEFT">
                                 <children>
                                    <Label text="Cliente:" style="-fx-font-weight: bold; -fx-min-width: 50;"/>
                                    <TextField fx:id="txtCliente" promptText="Nome do cliente..." HBox.hgrow="ALWAYS" styleClass="text-field-search"/>
                                 </children>
                              </HBox>
                              
                              <HBox spacing="10" alignment="CENTER">
                                 <children>
                                    <Button fx:id="btnBuscarFiltros" text="Buscar" styleClass="button-primary" onAction="#onBuscarComFiltros"/>
                                    <Button fx:id="btnLimparFiltros" text="Limpar" styleClass="button-secondary" onAction="#onLimparFiltros"/>
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </content>
                  </TitledPane>
                  
                  <TitledPane text="Lista de Cupons" expanded="true" collapsible="false">
                     <content>
                        <TableView fx:id="tblCupons" styleClass="table-view" prefHeight="300">
                           <columns>
                              <TableColumn fx:id="colNumero" text="Número" prefWidth="80"/>
                              <TableColumn fx:id="colData" text="Data" prefWidth="120"/>
                              <TableColumn fx:id="colCliente" text="Cliente" prefWidth="150"/>
                              <TableColumn fx:id="colValor" text="Valor" prefWidth="80"/>
                              <TableColumn fx:id="colStatus" text="Status" prefWidth="80"/>
                              <TableColumn fx:id="colAcoes" text="Ações" prefWidth="100"/>
                           </columns>
                        </TableView>
                     </content>
                  </TitledPane>
                  
                  <!-- Resumo -->
                  <VBox spacing="5" style="-fx-background-color: #f8f9fa; -fx-padding: 10; -fx-border-color: #dee2e6; -fx-border-radius: 5;">
                     <children>
                        <HBox alignment="CENTER_LEFT">
                           <children>
                              <Label text="Total Cupons:" style="-fx-font-weight: bold;"/>
                              <Region />
                              <Label fx:id="lblTotalCupons" text="0" style="-fx-font-weight: bold;"/>
                           </children>
                        </HBox>
                        <HBox alignment="CENTER_LEFT">
                           <children>
                              <Label text="Valor Total:" style="-fx-font-weight: bold;"/>
                              <Region />
                              <Label fx:id="lblValorTotalGeral" text="R$ 0,00" style="-fx-font-weight: bold; -fx-text-fill: #28a745;"/>
                           </children>
                        </HBox>
                     </children>
                  </VBox>
               </children>
            </VBox>
         </items>
      </SplitPane>
   </center>
   
   <bottom>
      <HBox style="-fx-padding: 10; -fx-background-color: #34495e; -fx-alignment: center_left;" spacing="20">
         <children>
            <Label fx:id="lblStatusOperacao" text="Pronto para operar" style="-fx-text-fill: #28a745; -fx-font-weight: bold;"/>
            <Region />
            <Label fx:id="lblEmpresa" text="Hermes Comercial Ltda" style="-fx-text-fill: white; -fx-font-size: 12px;"/>
         </children>
      </HBox>
   </bottom>
   
</BorderPane>
