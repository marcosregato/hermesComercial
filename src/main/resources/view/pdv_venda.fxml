<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/11" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.br.hermescomercial.controller.pdv.PDVVendaController"
      spacing="15" styleClass="content-vbox, venda-container" style="-fx-padding: 20;">
   
   <!-- Cabeçalho da Venda -->
   <HBox spacing="20" alignment="CENTER_LEFT" styleClass="venda-header">
      <children>
         <VBox spacing="5">
            <children>
               <Label text="Nº Venda:" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
               <Label fx:id="lblNumeroVenda" text="V001" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
            </children>
         </VBox>
         <VBox spacing="5">
            <children>
               <Label text="Data/Hora:" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
               <Label fx:id="lblDataHora" text="19/04/2026 17:00" style="-fx-font-size: 16px; -fx-text-fill: #34495e;"/>
            </children>
         </VBox>
         <VBox spacing="5">
            <children>
               <Label text="Operador:" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
               <Label fx:id="lblOperador" text="Operador" style="-fx-font-size: 16px; -fx-text-fill: #34495e;"/>
            </children>
         </VBox>
         <Region HBox.hgrow="ALWAYS"/>
         <Button fx:id="btnVoltar" text="Voltar" styleClass="button-secondary" onAction="#onVoltar"/>
      </children>
   </HBox>
   
   <Separator style="-fx-background-color: #bdc3c7;"/>
   
   <!-- Conteúdo Principal -->
   <HBox spacing="20" HBox.hgrow="ALWAYS">
      <children>
         <!-- Lado Esquerdo - Produtos e Carrinho -->
         <VBox spacing="15" HBox.hgrow="ALWAYS">
            <children>
               <!-- Área de Produtos -->
               <TitledPane text="Produtos" expanded="true" collapsible="false" styleClass="titled-pane-responsive">
                  <content>
                     <VBox spacing="10">
                        <children>
                           <!-- Busca de Produtos -->
                           <HBox spacing="10" alignment="CENTER_LEFT">
                              <children>
                                 <TextField fx:id="txtBuscarProduto" promptText="Código, descrição ou código de barras..." 
                                           HBox.hgrow="ALWAYS" styleClass="text-field-search"/>
                                 <Button fx:id="btnBuscar" text="Buscar" styleClass="button-primary" onAction="#onBuscarProduto"/>
                                 <Button fx:id="btnCodigoBarras" text="Cód. Barras" styleClass="button-info" onAction="#onCodigoBarras"/>
                              </children>
                           </HBox>
                           
                           <!-- Tabela de Produtos -->
                           <TableView fx:id="tblProdutos" styleClass="table-view, table-view-responsive" prefHeight="250">
                              <columns>
                                 <TableColumn fx:id="colCodigo" text="Código" prefWidth="60" styleClass="table-column-responsive"/>
                                 <TableColumn fx:id="colDescricao" text="Descrição" prefWidth="250" styleClass="table-column-responsive"/>
                                 <TableColumn fx:id="colPreco" text="Preço" prefWidth="80" styleClass="table-column-responsive"/>
                                 <TableColumn fx:id="colEstoque" text="Estoque" prefWidth="70" styleClass="table-column-responsive"/>
                                 <TableColumn fx:id="colAcoes" text="Ações" prefWidth="90" styleClass="table-column-responsive"/>
                              </columns>
                              <columnResizePolicy>
                                 <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                              </columnResizePolicy>
                           </TableView>
                        </children>
                     </VBox>
                  </content>
               </TitledPane>
               
               <!-- Carrinho de Compras -->
               <TitledPane text="Carrinho de Compras" expanded="true" collapsible="false" styleClass="titled-pane-responsive">
                  <content>
                     <VBox spacing="10">
                        <children>
                           <!-- Tabela do Carrinho -->
                           <TableView fx:id="tblCarrinho" styleClass="table-view, carrinho-table" prefHeight="200">
                              <columns>
                                 <TableColumn fx:id="colItemCodigo" text="Código" prefWidth="50" styleClass="table-column-responsive"/>
                                 <TableColumn fx:id="colItemDescricao" text="Descrição" prefWidth="200" styleClass="table-column-responsive"/>
                                 <TableColumn fx:id="colItemQtd" text="Qtd" prefWidth="60" styleClass="table-column-responsive"/>
                                 <TableColumn fx:id="colItemValor" text="Valor" prefWidth="70" styleClass="table-column-responsive"/>
                                 <TableColumn fx:id="colItemTotal" text="Total" prefWidth="70" styleClass="table-column-responsive"/>
                                 <TableColumn fx:id="colItemAcoes" text="Ações" prefWidth="70" styleClass="table-column-responsive"/>
                              </columns>
                              <columnResizePolicy>
                                 <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                              </columnResizePolicy>
                           </TableView>
                           
                           <!-- Resumo do Carrinho -->
                           <VBox spacing="5" style="-fx-background-color: #f8f9fa; -fx-padding: 10; -fx-border-color: #dee2e6; -fx-border-radius: 5;">
                              <children>
                                 <HBox alignment="CENTER_LEFT">
                                    <children>
                                       <Label text="Subtotal:" style="-fx-font-weight: bold;"/>
                                       <Region HBox.hgrow="ALWAYS"/>
                                       <Label fx:id="lblSubtotal" text="R$ 0,00" style="-fx-font-weight: bold;"/>
                                    </children>
                                 </HBox>
                                 <HBox alignment="CENTER_LEFT">
                                    <children>
                                       <Label text="Desconto:" style="-fx-font-weight: bold;"/>
                                       <Region HBox.hgrow="ALWAYS"/>
                                       <Label fx:id="lblDesconto" text="R$ 0,00" style="-fx-font-weight: bold;"/>
                                    </children>
                                 </HBox>
                                 <Separator/>
                                 <HBox alignment="CENTER_LEFT">
                                    <children>
                                       <Label text="Total:" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #28a745;"/>
                                       <Region />
                                       <Label fx:id="lblTotal" text="R$ 0,00" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #28a745;"/>
                                    </children>
                                 </HBox>
                              </children>
                           </VBox>
                           
                           <!-- Botões do Carrinho -->
                           <HBox spacing="10" alignment="CENTER">
                              <children>
                                 <Button fx:id="btnDesconto" text="Desconto" styleClass="button-warning" onAction="#onDesconto"/>
                                 <Button fx:id="btnCancelarItem" text="Cancelar Item" styleClass="button-danger" onAction="#onCancelarItem"/>
                                 <Button fx:id="btnLimparCarrinho" text="Limpar" styleClass="button-secondary" onAction="#onLimparCarrinho"/>
                              </children>
                           </HBox>
                        </children>
                     </VBox>
                  </content>
               </TitledPane>
            </children>
         </VBox>
         
         <!-- Lado Direito - Cliente e Finalização -->
         <VBox spacing="15" prefWidth="300">
            <children>
               <!-- Cliente -->
               <TitledPane text="Cliente" expanded="true" collapsible="false" styleClass="titled-pane-responsive">
                  <content>
                     <VBox spacing="10">
                        <children>
                           <!-- Busca de Cliente -->
                           <VBox spacing="5">
                              <children>
                                 <Label text="CPF/CNPJ:" style="-fx-font-weight: bold;"/>
                                 <HBox spacing="5">
                                    <children>
                                       <TextField fx:id="txtBuscarClienteCpfCnpj" promptText="Digite CPF ou CNPJ..." HBox.hgrow="ALWAYS" styleClass="text-field-search"
                          onKeyTyped="#validateCpfCnpjInput"/>
                                       <Button fx:id="btnBuscarCliente" text="Buscar" styleClass="button-primary" onAction="#onBuscarCliente"/>
                                    </children>
                                 </HBox>
                              </children>
                           </VBox>
                           
                           <!-- Dados do Cliente -->
                           <VBox spacing="5" style="-fx-background-color: #f8f9fa; -fx-padding: 10; -fx-border-radius: 5;">
                              <children>
                                 <Label fx:id="lblNomeCliente" text="Nenhum cliente selecionado" style="-fx-font-weight: bold; -fx-text-fill: #666;"/>
                                 <Label fx:id="lblCpfCnpjCliente" text="" style="-fx-text-fill: #666;"/>
                                 <Button fx:id="btnLimparCliente" text="Limpar Cliente" styleClass="button-secondary" onAction="#onLimparCliente"/>
                              </children>
                           </VBox>
                        </children>
                     </VBox>
                  </content>
               </TitledPane>
               
               <!-- Forma de Pagamento -->
               <TitledPane text="Pagamento" expanded="true" collapsible="false" styleClass="titled-pane-responsive">
                  <content>
                     <VBox spacing="10">
                        <children>
                           <!-- Métodos de Pagamento -->
                           <VBox spacing="8">
                              <children>
                                 <RadioButton fx:id="rbDinheiro" text="Dinheiro" selected="true"/>
                                 <RadioButton fx:id="rbCartao" text="Cartão"/>
                                 <RadioButton fx:id="rbPix" text="PIX"/>
                                 <RadioButton fx:id="rbOutro" text="Outro"/>
                              </children>
                           </VBox>
                           
                           <!-- Campo para Valor Recebido (Dinheiro) -->
                           <VBox fx:id="paneDinheiro" spacing="5">
                              <children>
                                 <Label text="Valor Recebido:" style="-fx-font-weight: bold;"/>
                                 <TextField fx:id="txtValorRecebido" promptText="0,00" styleClass="text-field-money"
                          onKeyTyped="#validateValorRecebidoInput"/>
                                 <Label fx:id="lblTroco" text="Troco: R$ 0,00" style="-fx-font-weight: bold; -fx-text-fill: #28a745;"/>
                              </children>
                           </VBox>
                        </children>
                     </VBox>
                  </content>
               </TitledPane>
               
               <!-- Botões de Finalização -->
               <VBox spacing="10">
                  <children>
                     <Button fx:id="btnFinalizar" text="FINALIZAR VENDA" styleClass="button-success, button-large" onAction="#onFinalizar"/>
                     <Button fx:id="btnCancelar" text="Cancelar Venda" styleClass="button-danger" onAction="#onCancelar"/>
                  </children>
               </VBox>
            </children>
         </VBox>
      </children>
   </HBox>
</VBox>
