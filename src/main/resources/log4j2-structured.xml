<?xml version="1.0" encoding="UTF-8"?>
<Configuration status="WARN" packages="com.br.hermescomercial.logging">
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n"/>
        </Console>
        
        <RollingFile name="RollingFile" fileName="logs/hermes-comercial.log"
                     filePattern="logs/hermes-comercial-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n</pattern>
            </PatternLayout>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="10 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>
        
        <RollingFile name="ErrorFile" fileName="logs/hermes-comercial-error.log"
                     filePattern="logs/hermes-comercial-error-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n%ex</pattern>
            </PatternLayout>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="10 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>
        
        <RollingFile name="AuditFile" fileName="logs/hermes-comercial-audit.log"
                     filePattern="logs/hermes-comercial-audit-%d{yyyy-MM-dd}-%i.log.gz">
            <PatternLayout>
                <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%t] %-5level %logger{36} - %msg%n</pattern>
            </PatternLayout>
            <Policies>
                <TimeBasedTriggeringPolicy interval="1" modulate="true"/>
                <SizeBasedTriggeringPolicy size="10 MB"/>
            </Policies>
            <DefaultRolloverStrategy max="30"/>
        </RollingFile>
    </Appenders>
    
    <Loggers>
        <Root level="info">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RollingFile"/>
        </Root>
        
        <Logger name="com.br.hermescomercial" level="debug" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RollingFile"/>
        </Logger>
        
        <Logger name="com.br.hermescomercial.service" level="debug" additivity="false">
            <AppenderRef ref="Console"/>
            <AppenderRef ref="RollingFile"/>
        </Logger>
        
        <Logger name="com.br.hermescomercial.dao" level="debug" additivity="false">
            <AppenderRef ref="RollingFile"/>
        </Logger>
        
        <Logger name="com.br.hermescomercial.repository" level="debug" additivity="false">
            <AppenderRef ref="RollingFile"/>
        </Logger>
        
        <Logger name="com.br.hermescomercial.controller" level="info" additivity="false">
            <AppenderRef ref="RollingFile"/>
        </Logger>
        
        <Logger name="error" level="error" additivity="false">
            <AppenderRef ref="ErrorFile"/>
        </Logger>
        
        <Logger name="audit" level="info" additivity="false">
            <AppenderRef ref="AuditFile"/>
        </Logger>
        
        <!-- Loggers de terceiros -->
        <Logger name="org.apache.ibatis" level="warn"/>
        <Logger name="org.springframework" level="warn"/>
        <Logger name="org.hibernate" level="warn"/>
    </Loggers>
</Configuration>
